{
  "permissions": {
    "allowed_commands": [
      "bash -n *",
      "make test",
      "make lint",
      "make check",
      "make clean",
      "make help",
      "bats *",
      "./spaceheater help",
      "./spaceheater version",
      "./spaceheater config",
      "./spaceheater list",
      "gh codespace list",
      "gh api *",
      "gh pr *",
      "git status",
      "git diff *",
      "git log *",
      "git branch *",
      "git remote *",
      "git rev-parse *",
      "python3 -c *",
      "shellcheck *",
      "which *",
      "command -v *"
    ]
  },
  "project": {
    "type": "cli-tool",
    "language": "bash",
    "testing_framework": "bats",
    "description": "GitHub Codespaces management tool"
  }
}