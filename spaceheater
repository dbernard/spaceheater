# ============================================================================
# MESSAGING FUNCTIONS
# ============================================================================

error() {
  local message="$*"
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # Output JSON error format consistent with output_json_error() schema
    jq -n --arg error "$message" \
      '{success: false, error: $error, timestamp: (now | todate)}' >&2
  else
    echo -e "${RED}${ICON_ERROR} Error: $message${NC}" >&2
  fi
  exit 1
}

info() {
  # Skip info messages in JSON mode (they would corrupt the JSON output)
  if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
    echo -e "${BLUE}${ICON_INFO} $*${NC}"
  fi
}

success() {
  # Skip success messages in JSON mode (they would corrupt the JSON output)
  if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
    echo -e "${GREEN}${ICON_SUCCESS} $*${NC}"
  fi
}

warn() {
  # Output warnings to stderr in JSON mode to not corrupt stdout JSON
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    jq -n --arg msg "$*" \
      '{"warning": true, "message": $msg, "timestamp": now | todate}' >&2
  else
    echo -e "${YELLOW}${ICON_WARNING} $*${NC}"
  fi
}

debug() {
  if [ "$DEBUG" = "true" ]; then
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      # Output debug to stderr in JSON format
      jq -n --arg msg "$*" \
        '{"debug": true, "message": $msg, "timestamp": now | todate}' >&2
    else
      echo -e "${BLUE}[DEBUG]${NC} $*" >&2
    fi
  fi
}

