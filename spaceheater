cmd_create() {
  init_repo_config
  local count="${1:-1}"

  if ! [[ "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ]; then
    error "Count must be a positive integer"
  fi

  # Cap at 3 codespaces per invocation
  if [ "$count" -gt 3 ]; then
    warn "Limiting to 3 codespaces per invocation (requested: $count)"
    count=3
  fi

  info "Creating $count codespace(s) for $REPO (branch: $BRANCH)..."

  # Determine machine type to use
  local effective_machine="$MACHINE"
  if [ -z "$effective_machine" ]; then
    # No machine specified, try to detect default
    info "  Detecting default machine type..."
    effective_machine=$(get_default_machine)
    info "  Machine type: $effective_machine (auto-detected)"
  else
    info "  Machine type: $effective_machine (user-specified)"
    validate_machine_type "$effective_machine"
  fi

  if [ -n "$RETENTION" ]; then
    info "  Retention: $RETENTION (user-specified)"
  fi

  if [ -n "$IDLE_TIMEOUT" ]; then
    info "  Idle timeout: $IDLE_TIMEOUT (user-specified)"
  fi

  if [ -n "$DEVCONTAINER_PATH" ]; then
    info "  Devcontainer: $DEVCONTAINER_PATH (user-specified)"
  fi

  if [ -n "$LOCATION" ]; then
    info "  Region: $LOCATION (user-specified)"
  fi

  echo

  local created=0
  local failed=0
  local -a created_names=()

  for i in $(seq 1 "$count"); do
    # Don't show progress output in JSON mode
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "[$i/$count] Creating codespace..."
      debug "Creating codespace with: repo=$REPO branch=$BRANCH machine=$effective_machine"
    fi

    # Build args array with only explicitly set values
    local create_args=(
      --repo "$REPO"
      --branch "$BRANCH"
      --default-permissions
      --machine "$effective_machine"  # Always pass machine to prevent interactive prompts
    )

    if [ -n "$RETENTION" ]; then
      create_args+=(--retention-period "$RETENTION")
    fi

    if [ -n "$IDLE_TIMEOUT" ]; then
      create_args+=(--idle-timeout "$IDLE_TIMEOUT")
    fi

    if [ -n "$DEVCONTAINER_PATH" ]; then
      create_args+=(--devcontainer-path "$DEVCONTAINER_PATH")
    fi

    if [ -n "$LOCATION" ]; then
      create_args+=(--location "$LOCATION")
    fi

    if [ -n "$DISPLAY_NAME" ]; then
      # Append counter for uniqueness
      create_args+=(--display-name "${DISPLAY_NAME}-${i}")
    fi

    # Capture the output which contains the codespace name
    local output
    output="$(gh codespace create "${create_args[@]}" 2>&1)" || true

    # Extract codespace name from output (last line is the codespace name)
    local codespace_name
    codespace_name=$(echo "$output" | tail -1 | grep -E '^[a-z0-9]+-[a-z0-9]+-[a-z0-9-]+$' || echo "")

    if [ -n "$codespace_name" ]; then
      if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
        success "  ${ICON_CHECK} Created: $codespace_name"
      fi
      created=$((created + 1))
      created_names+=("$codespace_name")
    else
      if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
        warn "  ${ICON_CROSS} Failed to create codespace"
        echo "  Output: $output"
      fi
      failed=$((failed + 1))
    fi

    # Rate limit protection
    if [ "$i" -lt "$count" ]; then
      sleep 2
    fi
  done

  # Handle JSON output
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    if [ ${#created_names[@]} -gt 0 ]; then
      fetch_codespaces_by_names "${created_names[@]}" | output_multiple_codespaces_json "create" |
        jq --argjson created "$created" --argjson failed "$failed" --argjson requested "$count" \
          '. + {created_count: $created, failed_count: $failed, requested_count: $requested}'
    else
      # Output error JSON if all creations failed
      output_json_error "create" "Failed to create any codespaces" "{\"requested_count\":$count,\"created_count\":0,\"failed_count\":$failed}"
    fi
    return
  fi

  # Original text output
  echo
  success "Created $created codespace(s)"
  if [ "$failed" -gt 0 ]; then
    warn "Failed: $failed"
  fi

  info "\nCodespaces will fully build in the background (~5-10 minutes)"
  info "They'll auto-stop after idle timeout and be ready for instant start"
  info "\nRun 'spaceheater list' to see your codespaces"
  info "Run 'spaceheater start' to connect to one when ready"
}

cmd_list() {
  init_repo_config

  # Handle JSON output if requested
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # Build the complete JQ filter using our utilities
    local codespace_filter
    codespace_filter=$(build_codespace_json_filter true)

    # Use jq to transform the codespaces with our reusable filters
    get_all_codespaces | normalize_timestamps | jq --arg repo "$REPO" --arg branch "$BRANCH" "
      # Current timestamp for calculations
      (now | todate) as \$current_time |

      # Main output structure
      {
        codespaces: (.codespaces | map(
          $codespace_filter
        ) | sort_by(.created_at) | reverse),
        repository: \$repo,
        branch: \$branch,
        timestamp: \$current_time,
        total_count: .total_count
      }
    "
    return
  fi

  # Original formatted output
  echo -e "${BOLD}${ICON_BRAND} SPACEHEATER${NC} - Codespaces for ${CYAN}$REPO${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"

  # Arrays to hold categorized codespaces
  local -a hot_lines=()
  local -a warm_lines=()
  local -a transitioning_lines=()
  local -a cold_lines=()

  # Collect and categorize codespaces
  while IFS=$'\t' read -r state display_name branch has_uncommitted has_unpushed ahead behind name created_at; do
    # Calculate age in days for WARM/COLD determination
    local age_days
    age_days=$(calculate_age_days "$created_at")

    # Determine git cleanliness (clean = no uncommitted, no ahead, optionally behind is OK)
    local is_git_clean=false
    if [ "$has_uncommitted" != "true" ] && [ "$has_unpushed" != "true" ] && [ "$ahead" -eq 0 ]; then
      is_git_clean=true
    fi

    # Categorize by temperature
    local category=""
    case "$state" in
      Available)
        category="HOT"
        ;;
      Shutdown)
        # WARM = shutdown + clean git + recent (≤3 days)
        # COLD = shutdown + (dirty git OR old)
        if [ "$is_git_clean" = "true" ] && [ "$age_days" -le 3 ]; then
          category="WARM"
        else
          category="COLD"
        fi
        ;;
      Starting|Provisioning|ShuttingDown|Stopping)
        category="TRANSITIONING"
        ;;
      *)
        category="COLD"
        ;;
    esac

    # Determine git status indicator (dimmed for COLD codespaces)
    local git_indicator=""
    if [ "$category" = "COLD" ]; then
      # Dimmed indicators for cold codespaces
      if [ "$has_uncommitted" = "true" ] || [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
        git_indicator="${DIM}${RED}${ICON_DIRTY}${NC}"  # Dirty (has changes)
      elif [ "$behind" -gt 0 ]; then
        git_indicator="${DIM}${YELLOW}${ICON_BEHIND}${NC}"  # Behind remote
      else
        git_indicator="${DIM}${GREEN}${ICON_CLEAN}${NC}"  # Clean
      fi
    else
      # Normal indicators for hot/warm codespaces
      if [ "$has_uncommitted" = "true" ] || [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
        git_indicator="${RED}${ICON_DIRTY}${NC}"  # Dirty (has changes)
      elif [ "$behind" -gt 0 ]; then
        git_indicator="${YELLOW}${ICON_BEHIND}${NC}"  # Behind remote
      else
        git_indicator="${GREEN}${ICON_CLEAN}${NC}"  # Clean
      fi
    fi

    # Build git status details
    local git_details=""
    if [ "$has_uncommitted" = "true" ]; then
      git_details="${git_details}uncommitted"
    fi
    if [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
      if [ -n "$git_details" ]; then git_details="${git_details}, "; fi
      git_details="${git_details}${ahead}${ICON_ARROW_UP}"
    fi
    if [ "$behind" -gt 0 ]; then
      if [ -n "$git_details" ]; then git_details="${git_details}, "; fi
      git_details="${git_details}${behind}${ICON_ARROW_DOWN}"
    fi
    if [ -z "$git_details" ]; then
      git_details="clean"
    fi

    local age
    age=$(format_time_ago "$created_at")

    # Format the line (with dimmed text for COLD, state info for TRANSITIONING)
    local line=""
    if [ "$category" = "TRANSITIONING" ]; then
      # For transitioning codespaces, show the state instead of git details
      local state_display=""
      case "$state" in
        Starting) state_display="Starting up" ;;
        Provisioning) state_display="Provisioning" ;;
        ShuttingDown) state_display="Shutting down" ;;
        Stopping) state_display="Stopping" ;;
        *) state_display="$state" ;;
      esac
      line="${git_indicator}\t${display_name}\t${branch}\t[${state_display}]\t${DIM}(${age})${NC}"
    elif [ "$category" = "COLD" ]; then
      line="${git_indicator}\t${DIM}${display_name}\t${branch}\t[${git_details}]\t(${age})${NC}"
    else
      line="${git_indicator}\t${display_name}\t${branch}\t[${git_details}]\t${DIM}(${age})${NC}"
    fi

    # Add to appropriate array
    case "$category" in
      HOT)
        hot_lines+=("$line")
        ;;
      WARM)
        warm_lines+=("$line")
        ;;
      TRANSITIONING)
        transitioning_lines+=("$line")
        ;;
      COLD)
        cold_lines+=("$line")
        ;;
    esac
  done < <(get_codespaces_with_jq '.codespaces | sort_by(.created_at) | reverse | .[] |
      "\(.state)\t\(.display_name // .name)\t\(.git_status.ref // "unknown")\t\(.git_status.has_uncommitted_changes // false)\t\(.git_status.has_unpushed_changes // false)\t\(.git_status.ahead // 0)\t\(.git_status.behind // 0)\t\(.name)\t\(.created_at)"')

  # Display HOT section
  echo -e "${COLOR_HOT}${ICON_HOT} HOT${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#hot_lines[@]} -gt 0 ]; then
    printf '%b\n' "${hot_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No hot codespaces. Start one with 'spaceheater start'${NC}"
  fi
  echo

  # Display WARM section
  echo -e "${COLOR_WARM}${ICON_WARM} WARM${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#warm_lines[@]} -gt 0 ]; then
    printf '%b\n' "${warm_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No warm codespaces. Create with 'spaceheater create [number]'${NC}"
  fi
  echo

  # Display TRANSITIONING section (only if there are transitioning codespaces)
  if [ ${#transitioning_lines[@]} -gt 0 ]; then
    echo -e "${COLOR_HEATING}${ICON_HEATING} TRANSITIONING${NC}"
    echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
    printf '%b\n' "${transitioning_lines[@]}" | column -t -s $'\t'
    echo
  fi

  # Display COLD section
  echo -e "${COLOR_COLD}${ICON_COLD} COLD${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#cold_lines[@]} -gt 0 ]; then
    printf '%b\n' "${cold_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No cold codespaces${NC}"
  fi
  echo

  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  echo -e "${DIM}Git: ${GREEN}${ICON_CLEAN}${DIM}=Clean ${RED}${ICON_DIRTY}${DIM}=Has changes ${YELLOW}${ICON_BEHIND}${DIM}=Behind remote${NC}"
}

# Auto-select a clean codespace
auto_select_codespace() {
  local codespace_name=""

  # First try: Clean HOT codespaces (Available - immediately ready, no startup needed)
  codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Available" and
      (.git_status.has_uncommitted_changes // false) == false and
      (.git_status.has_unpushed_changes // false) == false and
      (.git_status.ahead // 0) == 0)) |
      sort_by(.created_at) | reverse | .[0].name // empty')

  if [ -z "$codespace_name" ]; then
    # Second try: Clean WARM codespaces (Shutdown - fully built but needs restart)
    codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Shutdown" and
        (.git_status.has_uncommitted_changes // false) == false and
        (.git_status.has_unpushed_changes // false) == false and
        (.git_status.ahead // 0) == 0)) |
        sort_by(.created_at) | reverse | .[0].name // empty')
  fi

  if [ -z "$codespace_name" ]; then
    error "No clean codespaces available.\n\nAutostart requires a codespace with no uncommitted changes.\nUse 'spaceheater start' for interactive selection or 'spaceheater create' to create new codespaces."
  fi

  echo "$codespace_name"
}

cmd_start() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater start organic sniffle" works without quotes
  local search_term="${*}"

  # Build command arguments
  local -a cmd_args=()
  local codespace_name=""

  # If search term provided, try to find matching codespace
  if [ -n "$search_term" ]; then
    debug "Searching for codespace matching: $search_term"

    # Fetch all codespaces with their names and display names
    local matches
    matches=$(find_codespace_by_pattern "$search_term")

    # Use interactive selection helper
    codespace_name=$(select_codespace_interactive "$matches" "$search_term")

    cmd_args+=(-c "$codespace_name")
  else
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      error "JSON output requires a codespace name or search term"
    fi
    info "Select a codespace to start..." >&2
  fi

  # Handle JSON output if requested
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    output_connection_json "start" "$codespace_name"
    return
  fi

  # Connect based on configured method
  # If no codespace name provided, gh will show its interactive menu
  case "$CONNECT_METHOD" in
    browser|web)
      gh codespace code --web "${cmd_args[@]}"
      ;;
    ssh)
      gh codespace ssh "${cmd_args[@]}"
      ;;
    code|vscode)
      gh codespace code "${cmd_args[@]}"
      ;;
    *)
      error "Unknown connection method: $CONNECT_METHOD\nValid options: browser, ssh, code"
      ;;
  esac
}

cmd_autostart() {
  init_repo_config

  if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
    info "Finding a clean codespace to start..."
  fi

  # Auto-select the best clean codespace
  local codespace_name
  codespace_name=$(auto_select_codespace)

  debug "Selected codespace: $codespace_name"
  local display_name
  display_name="$(get_display_name "$codespace_name")"

  # Handle JSON output if requested
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    output_connection_json "autostart" "$codespace_name"
    return
  fi

  info "Starting codespace: ${display_name:-$codespace_name}..."

  # Connect based on configured method
  case "$CONNECT_METHOD" in
    browser|web)
      info "Opening in browser..."
      gh codespace code --web -c "$codespace_name"
      ;;
    ssh)
      info "Connecting via SSH..."
      gh codespace ssh -c "$codespace_name"
      ;;
    code|vscode)
      info "Opening in VS Code..."
      gh codespace code -c "$codespace_name"
      ;;
    *)
      error "Unknown connection method: $CONNECT_METHOD\nValid options: browser, ssh, code"
      ;;
  esac
}

cmd_stop() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater stop stunning lamp" works without quotes
  local search_term="${*}"

  # Special case: stop all running codespaces
  if [ "$search_term" = "all" ]; then
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "Finding all running codespaces to stop..."
    fi

    # Fetch all codespace data once; extract running codespaces for the stop loop
    # and keep the full JSON for later output.
    local all_data
    all_data=$(get_all_codespaces | normalize_timestamps)
    local running_codespaces
    running_codespaces=$(echo "$all_data" | jq -r '
      .codespaces | map(select(.state == "Available")) | .[] | "\(.name)\t\(.display_name // .name)"')

    if [ -z "$running_codespaces" ]; then
      if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
        jq -n '{
          action: "stop",
          success: true,
          codespaces: [],
          count: 0,
          message: "No running codespaces found",
          timestamp: (now | todate)
        }'
        return 0
      fi
      info "No running codespaces found"
      return 0
    fi

    # Count how many we're stopping
    local count
    count=$(echo "$running_codespaces" | wc -l | tr -d ' ')
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "Found $count running codespace(s)"
      echo
    fi

    # Stop each codespace
    local stopped=0
    local failed=0
    local -a stopped_names=()
    while IFS=$'\t' read -r name display_name; do
      if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
        info "Stopping: $display_name"
      fi
      if gh codespace stop -c "$name" 2>/dev/null; then
        if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
          success "  ${ICON_CHECK} Stopped"
        fi
        stopped=$((stopped + 1))
        stopped_names+=("$name")
      else
        if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
          warn "  ${ICON_CROSS} Failed to stop"
        fi
        failed=$((failed + 1))
      fi
    done <<< "$running_codespaces"

    # Handle JSON output if requested — filter the already-fetched bulk data
    # to only include the codespaces we successfully stopped.
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      # Build a jq-friendly JSON array of stopped names for filtering
      local names_json
      names_json=$(printf '%s\n' "${stopped_names[@]}" | jq -R . | jq -s .)
      echo "$all_data" | jq --argjson names "$names_json" '
        [.codespaces[] | select(.name as $n | $names | index($n))]
      ' | output_multiple_codespaces_json "stop" "Stopped $stopped codespace(s)"
      return 0
    fi

    echo
    success "Stopped $stopped codespace(s)"
    if [ "$failed" -gt 0 ]; then
      warn "Failed: $failed"
    fi
    return 0
  fi

  if [ -z "$search_term" ]; then
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "Finding running codespace to stop..."
    fi

    # Get the most recently used running codespace
    local codespace_name
    codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Available")) |
             sort_by(.last_used_at // .created_at) | reverse | .[0].name // empty')

    if [ -z "$codespace_name" ]; then
      error "No running codespaces found"
    fi
  else
    # Search for matching codespace (similar to start command)
    debug "Searching for codespace matching: $search_term"

    # Fetch all codespaces with their names and display names
    local matches
    matches=$(find_codespace_by_pattern "$search_term")

    # Use interactive selection helper
    codespace_name=$(select_codespace_interactive "$matches" "$search_term")
  fi

  local display_name
  display_name="$(get_display_name "$codespace_name")"

  # Handle JSON output if requested
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # Stop the codespace first
    if gh codespace stop -c "$codespace_name" 2>/dev/null; then
      # Build the complete JQ filter using our utilities
      local codespace_filter
      codespace_filter=$(build_codespace_json_filter false)

      # Output JSON with codespace details
      gh api "/user/codespaces/$codespace_name" | normalize_timestamps | jq \
        --arg action "stop" \
        --arg msg "Stopped successfully" \
        "
        (now | todate) as \$current_time |
        {
          action: \$action,
          success: true,
          codespace: (. | $codespace_filter),
          message: \$msg,
          timestamp: \$current_time
        }
      "
    else
      # Output error as JSON
      output_json_error "stop" "Failed to stop codespace" "{\"codespace_name\":\"$codespace_name\"}"
      exit 1
    fi
    return
  fi

  info "Stopping codespace: ${display_name:-$codespace_name}..."

  if gh codespace stop -c "$codespace_name"; then
    success "Stopped successfully!"
  else
    error "Failed to stop codespace"
  fi
}

cmd_clean() {
  init_repo_config
  local days="${1:-7}"

  if ! [[ "$days" =~ ^[0-9]+$ ]]; then
    error "Days must be a positive integer"
  fi

  info "Finding codespaces older than $days days in $REPO..."

  local cutoff_date
  cutoff_date=$(python3 -c "
from datetime import datetime, timedelta, timezone
cutoff = datetime.now(timezone.utc) - timedelta(days=$days)
print(cutoff.strftime('%Y-%m-%dT%H:%M:%SZ'))
")

  # Fetch all codespace data once and normalize timestamps.
  # Keep the full JSON for later output; derive the tab-delimited list for loops.
  local all_data
  all_data=$(get_all_codespaces | normalize_timestamps)

  local to_delete
  to_delete=$(echo "$all_data" | jq -r --arg cutoff "$cutoff_date" '
      .codespaces |
      map(select(.created_at < $cutoff)) |
      .[] | "\(.name)\t\(.display_name // .name)\t\(.created_at)"')

  if [ -z "$to_delete" ]; then
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      jq -n --arg days "$days" '{
        action: "clean",
        success: true,
        deleted_count: 0,
        age_threshold_days: ($days | tonumber),
        message: "No codespaces older than \($days) days found",
        timestamp: (now | todate)
      }'
    else
      success "No codespaces older than $days days found."
    fi
    return 0
  fi

  # Count how many we found
  local total_found
  total_found=$(echo "$to_delete" | wc -l | tr -d ' ')

  # Handle JSON output - skip confirmation and delete automatically
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    local -a deleted_names=()
    local deleted=0
    local failed=0

    # Delete the codespaces
    while IFS=$'\t' read -r name display_name created_at; do
      if gh codespace delete -c "$name" --force 2>/dev/null; then
        deleted=$((deleted + 1))
        deleted_names+=("$name")
      else
        failed=$((failed + 1))
      fi
    done <<< "$to_delete"

    if [ ${#deleted_names[@]} -gt 0 ]; then
      # Filter the already-fetched bulk data to only successfully deleted codespaces
      local names_json
      names_json=$(printf '%s\n' "${deleted_names[@]}" | jq -R . | jq -s .)
      local codespace_filter
      codespace_filter=$(build_codespace_json_filter false)
      echo "$all_data" | jq --argjson names "$names_json" --arg days "$days" \
        --argjson deleted_count "$deleted" --argjson failed_count "$failed" \
        --argjson total_found "$total_found" '
        (now | todate) as $current_time |
        {
          action: "clean",
          success: true,
          codespaces: ([.codespaces[] | select(.name as $n | $names | index($n))] | map('"$codespace_filter"')),
          deleted_count: $deleted_count,
          failed_count: $failed_count,
          age_threshold_days: ($days | tonumber),
          total_found: $total_found,
          timestamp: $current_time
        }
      '
    else
      output_json_error "clean" "Failed to delete any codespaces" "{\"deleted_count\":0,\"failed_count\":$failed,\"age_threshold_days\":$days,\"total_found\":$total_found}"
    fi
    return
  fi

  # Original text output with confirmation
  echo "$to_delete" | while IFS=$'\t' read -r name display_name created_at; do
    echo -e "  - $display_name (created: $created_at)"
  done

  echo
  read -p "Delete these codespaces? [y/N] " -n 1 -r
  echo

  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    info "Cancelled."
    return 0
  fi

  echo "$to_delete" | while IFS=$'\t' read -r name display_name created_at; do
    info "Deleting: $display_name"
    if gh codespace delete -c "$name" --force; then
      success "  ${ICON_CHECK} Deleted"
    else
      warn "  ${ICON_CROSS} Failed to delete"
    fi
  done

  success "Cleanup complete!"
}

cmd_delete() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater delete stunning lamp" works without quotes
  local search_term="${*}"

  if [ -z "$search_term" ]; then
    error "Usage: spaceheater delete <codespace-name>"
  fi

  # Search for matching codespace (similar to start/stop commands)
  debug "Searching for codespace matching: $search_term"

  # Fetch all codespaces with their names and display names
  local matches
  matches=$(find_codespace_by_pattern "$search_term")

  # Use interactive selection helper
  local codespace_name
  codespace_name=$(select_codespace_interactive "$matches" "$search_term")

  # Get display name for the selected codespace
  local display_name
  display_name=$(echo "$matches" | grep "^$codespace_name" | cut -f2)

  # Handle JSON output - skip confirmation and interactive output
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    if gh codespace delete -c "$codespace_name" --force 2>/dev/null; then
      output_single_codespace_json "delete" "$codespace_name" "Codespace deleted successfully"
    else
      output_json_error "delete" "Failed to delete codespace" "{\"codespace_name\":\"$codespace_name\"}"
    fi
    return
  fi

  # Original text output with confirmation
  info "Deleting codespace: $display_name"

  # Add confirmation for safety
  read -p "Are you sure you want to delete '$display_name'? [y/N] " -n 1 -r
  echo

  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    info "Cancelled."
    return 0
  fi

  if gh codespace delete -c "$codespace_name" --force; then
    success "Deleted!"
  else
    error "Failed to delete codespace"
  fi
}

cmd_config_init() {
  local config_file="${1:-.spaceheater.conf}"
  local target_location=""

  # Determine where to create the config file
  if [ "$config_file" = ".spaceheater.conf" ]; then
    target_location="repository"
  elif [[ "$config_file" =~ \.config/spaceheater ]]; then
    target_location="user"
  else
    target_location="custom"
  fi

  # Check if file already exists
  local file_existed=false
  local overwritten=false
  if [ -f "$config_file" ]; then
    file_existed=true
    # Skip interactive prompt in JSON mode
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      # In JSON mode, don't overwrite by default - return error
      jq -n \
        --arg file "$config_file" \
        --arg location "$target_location" \
        '{
          success: false,
          error: "Config file already exists",
          file_path: $file,
          location: $location,
          overwritten: false,
          timestamp: (now | todate)
        }'
      return 1
    else
      warn "Config file already exists: $config_file"
      read -p "Overwrite? [y/N] " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        info "Cancelled."
        return 0
      fi
      overwritten=true
    fi
  fi

  # Create parent directory if needed
  local config_dir
  config_dir=$(dirname "$config_file")
  local dir_created=false
  if [ ! -d "$config_dir" ] && [ "$config_dir" != "." ]; then
    mkdir -p "$config_dir"
    dir_created=true
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "Created directory: $config_dir"
    fi
  fi

  # Create template config file
  cat > "$config_file" << 'EOF'
# Spaceheater Configuration File
# All keys are optional and can be uncommented to override defaults
# Format: KEY=value (no spaces around =)
# Keys do NOT need SPACEHEATER_ prefix in config files

# Repository Settings
# REPO=owner/repo
# BRANCH=main

# Connection Settings
# CONNECT=browser    # Options: browser, ssh, code

# Codespace Overrides
# MACHINE=standardLinux
# RETENTION=168h
# IDLE_TIMEOUT=30m
# DEVCONTAINER_PATH=.devcontainer/devcontainer.json
# DISPLAY_NAME=my-codespace
# LOCATION=WestUs2

# UI Settings
# UI_STYLE=unicode   # Options: unicode, plain, simple

# Debug Settings
# DEBUG=false
EOF

  # Get absolute path for JSON output
  local abs_path
  abs_path=$(cd "$(dirname "$config_file")" && pwd)/$(basename "$config_file")

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    jq -n \
      --arg file "$abs_path" \
      --arg location "$target_location" \
      --argjson dir_created "$dir_created" \
      --argjson file_existed "$file_existed" \
      --argjson overwritten "$overwritten" \
      '{
        success: true,
        message: "Created config template",
        file_path: $file,
        location: $location,
        directory_created: $dir_created,
        file_existed: $file_existed,
        overwritten: $overwritten,
        template: "default",
        timestamp: (now | todate)
      }'
  else
    success "Created config template: $config_file"
    echo ""
    info "Edit this file to customize your configuration."
    info "Lines starting with # are comments and will be ignored."
    echo ""
    info "Config file precedence (highest to lowest):"
    info "  1. Environment variables (SPACEHEATER_*)"
    info "  2. Repository config (.spaceheater.conf)"
    info "  3. User config (~/.config/spaceheater/config)"
    info "  4. System config (/etc/spaceheater/config)"
    info "  5. Built-in defaults"
    echo ""
    info "To edit: spaceheater config edit"
  fi
}

cmd_config_edit() {
  local user_config="${XDG_CONFIG_HOME:-$HOME/.config}/spaceheater/config"
  local config_type="user"

  # Check if in a git repo for .spaceheater.conf
  local repo_config_available=false
  if git rev-parse --git-dir &>/dev/null 2>&1 && [ -f ".spaceheater.conf" ]; then
    repo_config_available=true
    if [ "${OUTPUT_FORMAT:-}" != "json" ]; then
      info "Found repository config: .spaceheater.conf"
      read -p "Edit repository config instead of user config? [Y/n] " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        user_config=".spaceheater.conf"
        config_type="repository"
      fi
    else
      # In JSON mode, prefer repository config if it exists
      user_config=".spaceheater.conf"
      config_type="repository"
    fi
  fi

  # Create config if it doesn't exist
  local file_exists=true
  if [ ! -f "$user_config" ]; then
    file_exists=false
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      # In JSON mode, return info about non-existent file
      jq -n \
        --arg file "$user_config" \
        --arg config_type "$config_type" \
        '{
          success: false,
          error: "Config file does not exist",
          message: "Use \"spaceheater config init\" to create a config file first",
          file_path: $file,
          config_type: $config_type,
          file_exists: false,
          timestamp: (now | todate)
        }'
      return 1
    else
      info "Config file doesn't exist. Creating template..."
      cmd_config_init "$user_config"
      echo ""
    fi
  fi

  # Use $EDITOR or fall back to sensible defaults
  local editor="${EDITOR:-}"
  if [ -z "$editor" ]; then
    if command -v nano &>/dev/null; then
      editor="nano"
    elif command -v vim &>/dev/null; then
      editor="vim"
    elif command -v vi &>/dev/null; then
      editor="vi"
    else
      if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
        jq -n \
          --arg file "$user_config" \
          '{
            success: false,
            error: "No editor found",
            message: "Set EDITOR environment variable or install nano/vim",
            file_path: $file,
            timestamp: (now | todate)
          }'
        return 1
      else
        error "No editor found. Set EDITOR environment variable or install nano/vim."
      fi
    fi
  fi

  # Get absolute path for JSON output
  local abs_path
  abs_path=$(cd "$(dirname "$user_config")" && pwd)/$(basename "$user_config")

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # In JSON mode, don't actually open the editor - return info about what would be edited
    jq -n \
      --arg file "$abs_path" \
      --arg editor "$editor" \
      --arg config_type "$config_type" \
      --argjson file_exists "$file_exists" \
      --argjson repo_available "$repo_config_available" \
      '{
        success: true,
        message: "Config edit information (editor not opened in JSON mode)",
        file_path: $file,
        editor: $editor,
        config_type: $config_type,
        file_exists: $file_exists,
        repository_config_available: $repo_available,
        note: "Use text output mode to interactively edit the config file",
        timestamp: (now | todate)
      }'
  else
    info "Opening config file in $editor..."
    "$editor" "$user_config"

    success "Config file updated!"
    info "Run 'spaceheater config' to see current configuration."
  fi
}

cmd_config() {
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # Helper function to determine the source of a configuration value
    get_config_source() {
      local var_name="$1"
      local env_var="SPACEHEATER_${var_name}"

      # Check if set in environment
      if [[ " $ENV_VARS_SET " =~ \ $env_var\  ]]; then
        echo "environment"
      # Check if value is set (from config file)
      elif [ -n "${!env_var:-}" ]; then
        echo "config_file"
      else
        echo "default"
      fi
    }

    # Collect loaded config files
    local config_files_json="[]"
    if [ -n "$LOADED_CONFIG_FILES" ]; then
      while IFS= read -r config_file; do
        config_files_json=$(echo "$config_files_json" | jq --arg file "$config_file" '. + [$file]')
      done <<< "$LOADED_CONFIG_FILES"
    fi

    # Detect current repository values
    local detected_repo=""
    local detected_branch=""
    local devcontainer_path=""
    local devcontainer_cpus=""
    local devcontainer_memory=""

    if detect_repo &>/dev/null; then
      detected_repo=$(detect_repo)
      detected_branch=$(detect_default_branch)

      if [ -f ".devcontainer/devcontainer.json" ]; then
        devcontainer_path=".devcontainer/devcontainer.json"
        if command -v jq &>/dev/null; then
          IFS=$'\t' read -r devcontainer_cpus devcontainer_memory < <(parse_devcontainer_requirements ".devcontainer/devcontainer.json")
        fi
      elif [ -f ".devcontainer.json" ]; then
        devcontainer_path=".devcontainer.json"
        if command -v jq &>/dev/null; then
          IFS=$'\t' read -r devcontainer_cpus devcontainer_memory < <(parse_devcontainer_requirements ".devcontainer.json")
        fi
      fi
    fi

    # Build JSON output
    jq -n \
      --argjson config_files "$config_files_json" \
      --arg repo_value "${SPACEHEATER_REPO:-}" \
      --arg repo_source "$(get_config_source REPO)" \
      --arg branch_value "${SPACEHEATER_BRANCH:-}" \
      --arg branch_source "$(get_config_source BRANCH)" \
      --arg connect_value "${CONNECT_METHOD:-browser}" \
      --arg connect_source "$(get_config_source CONNECT)" \
      --arg machine_value "${MACHINE:-}" \
      --arg machine_source "$(get_config_source MACHINE)" \
      --arg retention_value "${RETENTION:-}" \
      --arg retention_source "$(get_config_source RETENTION)" \
      --arg idle_timeout_value "${IDLE_TIMEOUT:-}" \
      --arg idle_timeout_source "$(get_config_source IDLE_TIMEOUT)" \
      --arg devcontainer_path_value "${DEVCONTAINER_PATH:-}" \
      --arg devcontainer_path_source "$(get_config_source DEVCONTAINER_PATH)" \
      --arg location_value "${LOCATION:-}" \
      --arg location_source "$(get_config_source LOCATION)" \
      --arg display_name_value "${DISPLAY_NAME:-}" \
      --arg display_name_source "$(get_config_source DISPLAY_NAME)" \
      --arg ui_style_value "${SPACEHEATER_UI_STYLE:-unicode}" \
      --arg ui_style_source "$(get_config_source UI_STYLE)" \
      --arg debug_value "${DEBUG:-false}" \
      --arg debug_source "$(get_config_source DEBUG)" \
      --arg detected_repo "$detected_repo" \
      --arg detected_branch "$detected_branch" \
      --arg detected_devcontainer "$devcontainer_path" \
      --arg detected_cpus "$devcontainer_cpus" \
      --arg detected_memory "$devcontainer_memory" \
      '{
        loaded_config_files: $config_files,
        repository: {
          repo: {
            value: (if $repo_value != "" then $repo_value else null end),
            source: $repo_source,
            detected: (if $detected_repo != "" then $detected_repo else null end)
          },
          branch: {
            value: (if $branch_value != "" then $branch_value else null end),
            source: $branch_source,
            detected: (if $detected_branch != "" then $detected_branch else null end)
          }
        },
        connection: {
          method: {
            value: $connect_value,
            source: $connect_source,
            options: ["browser", "ssh", "code"]
          }
        },
        codespace_overrides: {
          machine: {
            value: (if $machine_value != "" then $machine_value else null end),
            source: $machine_source
          },
          retention: {
            value: (if $retention_value != "" then $retention_value else null end),
            source: $retention_source
          },
          idle_timeout: {
            value: (if $idle_timeout_value != "" then $idle_timeout_value else null end),
            source: $idle_timeout_source
          },
          devcontainer_path: {
            value: (if $devcontainer_path_value != "" then $devcontainer_path_value else null end),
            source: $devcontainer_path_source,
            detected: (if $detected_devcontainer != "" then $detected_devcontainer else null end)
          },
          location: {
            value: (if $location_value != "" then $location_value else null end),
            source: $location_source
          },
          display_name: {
            value: (if $display_name_value != "" then $display_name_value else null end),
            source: $display_name_source
          }
        },
        ui: {
          style: {
            value: $ui_style_value,
            source: $ui_style_source,
            options: ["unicode", "plain", "simple"]
          }
        },
        debug: {
          enabled: {
            value: $debug_value,
            source: $debug_source
          }
        },
        detected: {
          repository: (if $detected_repo != "" then $detected_repo else null end),
          branch: (if $detected_branch != "" then $detected_branch else null end),
          devcontainer: (if $detected_devcontainer != "" then {
            path: $detected_devcontainer,
            requirements: {
              cpus: (if $detected_cpus != "" then $detected_cpus else null end),
              memory: (if $detected_memory != "" then $detected_memory else null end)
            }
          } else null end)
        },
        timestamp: (now | todate)
      }'
  else
    echo -e "${BOLD}${ICON_BRAND} SPACEHEATER CONFIGURATION${NC}"
    echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"

    # Show loaded config files
    echo -e "${BOLD}Loaded Config Files:${NC}"
    if [ -z "$LOADED_CONFIG_FILES" ]; then
      echo -e "  ${DIM}No config files found (using environment variables and defaults)${NC}"
    else
      while IFS= read -r config_file; do
        echo -e "  ${GREEN}${ICON_CHECK}${NC} $config_file"
      done <<< "$LOADED_CONFIG_FILES"
    fi
    echo ""

    echo -e "${BOLD}Repository Settings:${NC}"
    echo -e "  ${ICON_REPO} SPACEHEATER_REPO:              ${CYAN}${SPACEHEATER_REPO:-<auto-detect from git>}${NC}"
    echo -e "  ${ICON_BRANCH} SPACEHEATER_BRANCH:            ${CYAN}${SPACEHEATER_BRANCH:-<auto-detect from repo>}${NC}"
    echo ""

    echo -e "${BOLD}Connection Settings:${NC}"
    echo -e "  ${ICON_ARROW_RIGHT} SPACEHEATER_CONNECT:           ${CYAN}${CONNECT_METHOD:-browser}${NC} ${DIM}(options: browser, ssh, code)${NC}"
    echo ""

    echo -e "${BOLD}Codespace Overrides ${DIM}(optional):${NC}"
    echo -e "  ${ICON_MACHINE} SPACEHEATER_MACHINE:           ${CYAN}${MACHINE:-<use devcontainer or GitHub default>}${NC}"
    echo -e "  ${ICON_TIMER} SPACEHEATER_RETENTION:         ${CYAN}${RETENTION:-<use GitHub default>}${NC}"
    echo -e "  ${ICON_TIMER} SPACEHEATER_IDLE_TIMEOUT:      ${CYAN}${IDLE_TIMEOUT:-<use GitHub/org default>}${NC}"
    echo -e "  ${ICON_REPO} SPACEHEATER_DEVCONTAINER_PATH: ${CYAN}${DEVCONTAINER_PATH:-<auto-detect>}${NC}"
    echo -e "  ${ICON_REGION} SPACEHEATER_LOCATION:          ${CYAN}${LOCATION:-<auto-detect closest region>}${NC}"
    echo -e "  ${ICON_CALENDAR} SPACEHEATER_DISPLAY_NAME:      ${CYAN}${DISPLAY_NAME:-<GitHub-generated>}${NC}"
    echo ""

    echo -e "${BOLD}UI Settings:${NC}"
    echo -e "  ${ICON_INFO} SPACEHEATER_UI_STYLE:          ${CYAN}${SPACEHEATER_UI_STYLE:-unicode}${NC} ${DIM}(options: unicode, plain, simple)${NC}"
    echo ""

    echo -e "${BOLD}Debug Settings:${NC}"
    echo -e "  ${ICON_INFO} SPACEHEATER_DEBUG:             ${CYAN}${DEBUG:-false}${NC}"
    echo ""

    echo -e "${BOLD}Current Detection:${NC}"

    # Try to detect and show current values
    if detect_repo &>/dev/null; then
      local detected_repo
      detected_repo=$(detect_repo)
      echo -e "  ${ICON_CHECK} Detected Repository:           ${GREEN}$detected_repo${NC}"
      echo -e "  ${ICON_CHECK} Detected Branch:               ${GREEN}$(detect_default_branch)${NC}"

      # Try to show devcontainer info if we're in the repo
      if [ -f ".devcontainer/devcontainer.json" ]; then
        echo -e "  ${ICON_CHECK} Devcontainer:                  ${GREEN}.devcontainer/devcontainer.json (found)${NC}"

        # Try to extract hostRequirements if jq is available
        if command -v jq &>/dev/null; then
          local cpus="" memory=""
          IFS=$'\t' read -r cpus memory < <(parse_devcontainer_requirements ".devcontainer/devcontainer.json")
          if [ -n "$cpus" ] || [ -n "$memory" ]; then
            echo -e "  ${ICON_CHECK} Devcontainer Requirements:     ${GREEN}${cpus:+$cpus cores}${cpus:+, }${memory:+$memory RAM}${NC}"
          fi
        fi
      elif [ -f ".devcontainer.json" ]; then
        echo -e "  ${ICON_CHECK} Devcontainer:                  ${GREEN}.devcontainer.json (found)${NC}"

        if command -v jq &>/dev/null; then
          local cpus="" memory=""
          IFS=$'\t' read -r cpus memory < <(parse_devcontainer_requirements ".devcontainer.json")
          if [ -n "$cpus" ] || [ -n "$memory" ]; then
            echo -e "  ${ICON_CHECK} Devcontainer Requirements:     ${GREEN}${cpus:+$cpus cores}${cpus:+, }${memory:+$memory RAM}${NC}"
          fi
        fi
      else
        echo -e "  ${ICON_INFO} Devcontainer:                  ${DIM}<none - will use GitHub default image>${NC}"
      fi
    else
      echo -e "  ${ICON_CROSS} Detected Repository:           ${DIM}<none - not in a git repo>${NC}"
    fi

    echo -e "\n${DIM}────────────────────────────────────────────────────────────────${NC}"
    echo -e "${BOLD}${ICON_INFO} Configuration Philosophy:${NC}"
    echo -e "  Spaceheater respects your repository's devcontainer and GitHub's defaults."
    echo -e "  Only set environment variables when you need to override these defaults."
    echo ""
    echo -e "${BOLD}${ICON_NEXT} Available Commands:${NC}"
    echo -e "  ${CYAN}spaceheater config init${NC}      Create a config file template"
    echo -e "  ${CYAN}spaceheater config edit${NC}      Edit your config file"
    echo -e "  ${CYAN}spaceheater config validate${NC}  Validate config file syntax"
    echo ""
    echo -e "${BOLD}${ICON_NEXT} Configuration Precedence (highest to lowest):${NC}"
    echo -e "  ${DIM}1. CLI arguments${NC}"
    echo -e "  ${DIM}2. Environment variables (SPACEHEATER_*)${NC}"
    echo -e "  ${DIM}3. Repository config (.spaceheater.conf)${NC}"
    echo -e "  ${DIM}4. User config (~/.config/spaceheater/config)${NC}"
    echo -e "  ${DIM}5. System config (/etc/spaceheater/config)${NC}"
    echo -e "  ${DIM}6. Built-in defaults${NC}"
  fi
}

# ============================================================================
# SCHEDULE COMMAND - LAUNCHD INTEGRATION
# ============================================================================

# Platform detection
_is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

# Resolve absolute path to spaceheater executable
_spaceheater_path() {
  if [ -n "${BASH_SOURCE[0]:-}" ]; then
    local resolved
    resolved=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")
    echo "$resolved"
  elif command -v spaceheater &>/dev/null; then
    command -v spaceheater
  else
    echo "$0"
  fi
}

# Convert owner/repo to slug for labels/filenames
_repo_slug() {
  local repo="$1"
  echo "${repo//\//-}"
}

# Get launchd label for a repo
_schedule_label() {
  local repo="$1"
  echo "com.spaceheater.schedule.$(_repo_slug "$repo")"
}

# Get plist file path for a repo
_schedule_plist_path() {
  local repo="$1"
  echo "$HOME/Library/LaunchAgents/$(_schedule_label "$repo").plist"
}

# Get log directory path
_schedule_log_dir() {
  echo "${SPACEHEATER_SCHEDULE_LOG_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/spaceheater/logs}"
}

# Resolve preset name to hour/minute/weekday values
# Outputs: hour minute weekday (space-separated)
# weekday is comma-separated list or empty for "every day"
_resolve_preset() {
  local preset="$1"
  case "$preset" in
    weekday-morning)  echo "8 0 1,2,3,4,5" ;;
    weekday-evening)  echo "18 0 1,2,3,4,5" ;;
    hourly)           echo "- 0 -" ;;
    daily)            echo "9 0 -" ;;
    twice-daily)      echo "8,17 0 -" ;;
    *)
      error "Unknown preset: $preset\nValid presets: weekday-morning, weekday-evening, hourly, daily, twice-daily"
      ;;
  esac
}

# Generate StartCalendarInterval XML from hour/minute/weekday values
# hour: integer, comma-separated list, or "-" for every hour
# minute: integer
# weekday: comma-separated list (0=Sunday) or "-" for every day
_generate_calendar_interval_xml() {
  local hour="$1"
  local minute="$2"
  local weekday="$3"

  local xml="    <key>StartCalendarInterval</key>"$'\n'

  # Build list of (hour, weekday) combinations to expand
  local -a hours=()
  local -a weekdays=()

  if [ "$hour" = "-" ]; then
    hours=("-")
  else
    IFS=',' read -ra hours <<< "$hour"
  fi

  if [ "$weekday" = "-" ]; then
    weekdays=("-")
  else
    IFS=',' read -ra weekdays <<< "$weekday"
  fi

  # Count total dicts to determine if we need an array wrapper
  local total_dicts=0
  total_dicts=$(( ${#hours[@]} * ${#weekdays[@]} ))

  if [ "$total_dicts" -gt 1 ]; then
    xml+="    <array>"$'\n'
  fi

  for h in "${hours[@]}"; do
    for w in "${weekdays[@]}"; do
      if [ "$total_dicts" -gt 1 ]; then
        xml+="      <dict>"$'\n'
      else
        xml+="    <dict>"$'\n'
      fi
      if [ "$h" != "-" ]; then
        xml+="        <key>Hour</key>"$'\n'
        xml+="        <integer>$h</integer>"$'\n'
      fi
      xml+="        <key>Minute</key>"$'\n'
      xml+="        <integer>$minute</integer>"$'\n'
      if [ "$w" != "-" ]; then
        xml+="        <key>Weekday</key>"$'\n'
        xml+="        <integer>$w</integer>"$'\n'
      fi
      if [ "$total_dicts" -gt 1 ]; then
        xml+="      </dict>"$'\n'
      else
        xml+="    </dict>"$'\n'
      fi
    done
  done

  if [ "$total_dicts" -gt 1 ]; then
    xml+="    </array>"
  fi

  echo "$xml"
}

# Generate a complete launchd plist file
_launchd_generate_plist() {
  local label="$1"
  local repo="$2"
  local count="$3"
  local hour="$4"
  local minute="$5"
  local weekday="$6"

  local spaceheater_path
  spaceheater_path=$(_spaceheater_path)
  local log_dir
  log_dir=$(_schedule_log_dir)
  local log_file="$log_dir/schedule.log"

  # Build PATH with common locations
  local schedule_path="/usr/local/bin:/usr/bin:/opt/homebrew/bin:$HOME/.local/bin"

  local calendar_xml
  calendar_xml=$(_generate_calendar_interval_xml "$hour" "$minute" "$weekday")

  cat <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$label</string>
    <key>ProgramArguments</key>
    <array>
        <string>$spaceheater_path</string>
        <string>schedule</string>
        <string>run</string>
        <string>$count</string>
        <string>--json</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>SPACEHEATER_REPO</key>
        <string>$repo</string>
        <key>PATH</key>
        <string>$schedule_path</string>
    </dict>
$calendar_xml
    <key>StandardOutPath</key>
    <string>$log_file</string>
    <key>StandardErrorPath</key>
    <string>$log_file</string>
</dict>
</plist>
PLIST
}

# Install a launchd agent from a plist file
_launchd_add() {
  local plist_path="$1"

  # Try modern launchctl API first, fall back to legacy
  if launchctl bootstrap "gui/$(id -u)" "$plist_path" 2>/dev/null; then
    return 0
  elif launchctl load "$plist_path" 2>/dev/null; then
    return 0
  else
    return 1
  fi
}

# Remove a launchd agent and delete its plist
_launchd_remove() {
  local label="$1"
  local plist_path="$2"

  # Try modern API first, fall back to legacy
  launchctl bootout "gui/$(id -u)" "$plist_path" 2>/dev/null ||
    launchctl unload "$plist_path" 2>/dev/null || true

  # Delete the plist file
  rm -f "$plist_path"
}

# List all spaceheater schedule plists
# Outputs tab-separated: label repo count hour minute weekday plist_path
_launchd_list() {
  local launch_agents_dir="$HOME/Library/LaunchAgents"
  local found=0

  for plist in "$launch_agents_dir"/com.spaceheater.schedule.*.plist; do
    [ -f "$plist" ] || continue
    found=1

    # Parse plist to extract values using python3 (available on macOS)
    python3 - "$plist" <<'PARSE_PLIST' 2>/dev/null || continue
import plistlib
import sys

plist_path = sys.argv[1]
with open(plist_path, 'rb') as f:
    pl = plistlib.load(f)

label = pl.get('Label', '')
env = pl.get('EnvironmentVariables', {})
repo = env.get('SPACEHEATER_REPO', '')
args = pl.get('ProgramArguments', [])

# Extract count from args: schedule run <count> --json
count = ''
for i, a in enumerate(args):
    if a == 'run' and i + 1 < len(args):
        count = args[i + 1]
        break

# Extract schedule from StartCalendarInterval
intervals = pl.get('StartCalendarInterval', {})
if isinstance(intervals, dict):
    intervals = [intervals]

hours = set()
minutes = set()
weekdays = set()
for iv in intervals:
    if 'Hour' in iv:
        hours.add(iv['Hour'])
    if 'Minute' in iv:
        minutes.add(iv['Minute'])
    if 'Weekday' in iv:
        weekdays.add(iv['Weekday'])

hour_str = ','.join(str(h) for h in sorted(hours)) if hours else '-'
minute_str = ','.join(str(m) for m in sorted(minutes)) if minutes else '0'
weekday_str = ','.join(str(w) for w in sorted(weekdays)) if weekdays else '-'

print(f'{label}\t{repo}\t{count}\t{hour_str}\t{minute_str}\t{weekday_str}\t{plist_path}')
PARSE_PLIST
  done

  if [ "$found" -eq 1 ]; then
    return 0
  else
    return 1
  fi
}

# Get launchctl status for a label
# Outputs: pid last_exit_status
# Note: `launchctl list <label>` returns a dict-style output, not tab-separated
_launchd_status() {
  local label="$1"

  local output
  if output=$(launchctl list "$label" 2>/dev/null); then
    # Parse dict-style output: "PID" = 12345; / "LastExitStatus" = 0;
    local pid=""
    local exit_status=""
    # Extract PID (only present when process is running)
    pid=$(echo "$output" | awk -F '= ' '/"PID"/ {gsub(/[^0-9]/,"",$2); print $2}' 2>/dev/null)
    exit_status=$(echo "$output" | awk -F '= ' '/LastExitStatus/ {gsub(/[^0-9]/,"",$2); print $2}' 2>/dev/null)
    # Output pipe-separated to avoid IFS read issues with empty leading fields
    echo "${pid:-}|${exit_status:-}"
  else
    echo "|"
  fi
}

# Count HOT + WARM codespaces for the current repo using JSON output
# Reuses the shared filter helpers so temperature logic stays in one place
count_hot_warm_codespaces() {
  local age_filter
  age_filter=$(get_age_calculation_filter)
  local git_clean_filter
  git_clean_filter=$(get_git_clean_jq_filter)
  local temp_filter
  temp_filter=$(get_temperature_jq_filter)

  local count
  count=$(get_all_codespaces | normalize_timestamps | jq "
    (now | todate) as \$current_time |
    [.codespaces[] |
      $age_filter
      $git_clean_filter as \$is_git_clean |
      $temp_filter as \$temp |
      select(\$temp == \"hot\" or \$temp == \"warm\")
    ] | length
  " 2>/dev/null) || count=0

  echo "$count"
}

# Describe a schedule in human-readable form
_describe_schedule() {
  local hour="$1"
  local minute="$2"
  local weekday="$3"

  local time_desc=""
  local day_desc=""

  # Format time
  if [ "$hour" = "-" ]; then
    time_desc="every hour at :$(printf '%02d' "$minute")"
  else
    local -a hour_parts=()
    IFS=',' read -ra hour_parts <<< "$hour"
    local -a time_parts=()
    for h in "${hour_parts[@]}"; do
      local period="AM"
      local display_h="$h"
      if [ "$h" -ge 12 ]; then
        period="PM"
        if [ "$h" -gt 12 ]; then
          display_h=$((h - 12))
        fi
      fi
      if [ "$h" -eq 0 ]; then
        display_h=12
        period="AM"
      fi
      time_parts+=("${display_h}:$(printf '%02d' "$minute") ${period}")
    done
    time_desc=$(IFS=', '; echo "${time_parts[*]}")
  fi

  # Format days
  if [ "$weekday" = "-" ]; then
    day_desc="every day"
  else
    local -a day_names=("Sun" "Mon" "Tue" "Wed" "Thu" "Fri" "Sat")
    local -a day_parts=()
    IFS=',' read -ra wd_parts <<< "$weekday"

    # Check if it's weekdays (1-5)
    if [ "${#wd_parts[@]}" -eq 5 ]; then
      local is_weekdays=true
      for w in "${wd_parts[@]}"; do
        if [ "$w" -lt 1 ] || [ "$w" -gt 5 ]; then
          is_weekdays=false
          break
        fi
      done
      if [ "$is_weekdays" = "true" ]; then
        day_desc="weekdays"
      fi
    fi

    if [ -z "$day_desc" ]; then
      for w in "${wd_parts[@]}"; do
        day_parts+=("${day_names[$w]}")
      done
      day_desc=$(IFS=', '; echo "${day_parts[*]}")
    fi
  fi

  echo "$time_desc, $day_desc"
}

# ============================================================================
# SCHEDULE COMMAND IMPLEMENTATIONS
# ============================================================================

cmd_schedule() {
  local subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    set)
      cmd_schedule_set "$@"
      ;;
    list|ls)
      cmd_schedule_list "$@"
      ;;
    remove|rm)
      cmd_schedule_remove "$@"
      ;;
    status)
      cmd_schedule_status "$@"
      ;;
    run)
      cmd_schedule_run "$@"
      ;;
    help|--help|-h)
      cmd_schedule_help
      ;;
    *)
      error "Unknown schedule subcommand: $subcmd\nValid subcommands: set, list, remove, status"
      ;;
  esac
}

cmd_schedule_set() {
  if ! _is_macos; then
    error "Scheduling requires macOS (launchd). Cron support is planned for a future release."
  fi

  # Parse arguments
  local count=""
  local preset=""
  local hour=""
  local minute=""
  local weekday=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --preset)
        [ $# -ge 2 ] || error "Missing value for --preset"
        preset="$2"
        shift 2
        ;;
      --preset=*)
        preset="${1#--preset=}"
        shift
        ;;
      --hour)
        [ $# -ge 2 ] || error "Missing value for --hour"
        hour="$2"
        shift 2
        ;;
      --hour=*)
        hour="${1#--hour=}"
        shift
        ;;
      --minute)
        [ $# -ge 2 ] || error "Missing value for --minute"
        minute="$2"
        shift 2
        ;;
      --minute=*)
        minute="${1#--minute=}"
        shift
        ;;
      --weekday)
        [ $# -ge 2 ] || error "Missing value for --weekday"
        weekday="$2"
        shift 2
        ;;
      --weekday=*)
        weekday="${1#--weekday=}"
        shift
        ;;
      -*)
        error "Unknown option: $1"
        ;;
      *)
        if [ -z "$count" ]; then
          count="$1"
        else
          error "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  # Validate count
  if [ -z "$count" ]; then
    error "Missing required argument: <count>\nUsage: spaceheater schedule set <count> --preset <name>"
  fi

  if ! [[ "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ] || [ "$count" -gt 3 ]; then
    error "Count must be between 1 and 3"
  fi

  # Resolve schedule: preset or custom flags
  if [ -n "$preset" ]; then
    if [ -n "$hour" ] || [ -n "$minute" ] || [ -n "$weekday" ]; then
      error "Cannot use --preset with --hour/--minute/--weekday"
    fi
    local schedule_values
    schedule_values=$(_resolve_preset "$preset")
    read -r hour minute weekday <<< "$schedule_values"
  else
    # Custom schedule - require at least --hour or --minute
    if [ -z "$hour" ] && [ -z "$minute" ]; then
      error "Must specify --preset <name> or --hour/--minute for custom schedule"
    fi
    hour="${hour:--}"
    minute="${minute:-0}"
    weekday="${weekday:--}"

    # Expand weekday ranges (e.g., 1-5 → 1,2,3,4,5)
    if [[ "$weekday" =~ ^([0-6])-([0-6])$ ]]; then
      local range_start="${BASH_REMATCH[1]}"
      local range_end="${BASH_REMATCH[2]}"
      if [ "$range_start" -gt "$range_end" ]; then
        error "Invalid weekday range: $weekday (start must be <= end, e.g., 1-5)"
      fi
      weekday=""
      for ((d=range_start; d<=range_end; d++)); do
        [ -n "$weekday" ] && weekday+=","
        weekday+="$d"
      done
    fi

    # Validate hour values
    if [ "$hour" != "-" ]; then
      local -a hour_vals=()
      IFS=',' read -ra hour_vals <<< "$hour"
      for h in "${hour_vals[@]}"; do
        if ! [[ "$h" =~ ^[0-9]+$ ]] || [ "$h" -gt 23 ]; then
          error "Invalid hour: $h (must be 0-23)"
        fi
      done
    fi

    # Validate minute
    if ! [[ "$minute" =~ ^[0-9]+$ ]] || [ "$minute" -gt 59 ]; then
      error "Invalid minute: $minute (must be 0-59)"
    fi

    # Validate weekday values
    if [ "$weekday" != "-" ]; then
      local -a wd_vals=()
      IFS=',' read -ra wd_vals <<< "$weekday"
      for w in "${wd_vals[@]}"; do
        if ! [[ "$w" =~ ^[0-6]$ ]]; then
          error "Invalid weekday: $w (must be 0-6, where 0=Sunday)"
        fi
      done
    fi
  fi

  init_repo_config

  local label
  label=$(_schedule_label "$REPO")
  local plist_path
  plist_path=$(_schedule_plist_path "$REPO")
  local log_dir
  log_dir=$(_schedule_log_dir)

  # Remove existing schedule for this repo if present
  if [ -f "$plist_path" ]; then
    _launchd_remove "$label" "$plist_path"
    debug "Removed existing schedule for $REPO"
  fi

  # Create log directory
  mkdir -p "$log_dir"

  # Generate and write plist
  _launchd_generate_plist "$label" "$REPO" "$count" "$hour" "$minute" "$weekday" > "$plist_path"

  # Install the agent
  if ! _launchd_add "$plist_path"; then
    rm -f "$plist_path"
    error "Failed to install launchd agent"
  fi

  local schedule_desc
  schedule_desc=$(_describe_schedule "$hour" "$minute" "$weekday")

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    jq -n \
      --arg action "schedule_set" \
      --arg repo "$REPO" \
      --argjson count "$count" \
      --arg schedule "$schedule_desc" \
      --arg label "$label" \
      --arg plist_path "$plist_path" \
      --arg log_dir "$log_dir" \
      '{
        action: $action,
        success: true,
        schedule: {
          repository: $repo,
          desired_count: $count,
          schedule: $schedule,
          label: $label,
          plist_path: $plist_path,
          log_dir: $log_dir
        },
        timestamp: (now | todate)
      }'
  else
    success "Schedule created for $REPO"
    info "  Target: $count HOT/WARM codespace(s)"
    info "  Schedule: $schedule_desc"
    info "  Log: $log_dir/schedule.log"
  fi
}

cmd_schedule_list() {
  if ! _is_macos; then
    error "Scheduling requires macOS (launchd). Cron support is planned for a future release."
  fi

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    local json_array="[]"

    while IFS=$'\t' read -r label repo count hour minute weekday plist_path; do
      local schedule_desc
      schedule_desc=$(_describe_schedule "$hour" "$minute" "$weekday")

      json_array=$(echo "$json_array" | jq \
        --arg label "$label" \
        --arg repo "$repo" \
        --argjson count "$count" \
        --arg schedule "$schedule_desc" \
        --arg hour "$hour" \
        --arg minute "$minute" \
        --arg weekday "$weekday" \
        --arg plist_path "$plist_path" \
        '. += [{
          label: $label,
          repository: $repo,
          desired_count: $count,
          schedule: $schedule,
          hour: $hour,
          minute: $minute,
          weekday: $weekday,
          plist_path: $plist_path
        }]')
    done < <(_launchd_list 2>/dev/null || true)

    jq -n \
      --argjson schedules "$json_array" \
      '{
        action: "schedule_list",
        success: true,
        schedules: $schedules,
        count: ($schedules | length),
        timestamp: (now | todate)
      }'
    return
  fi

  echo -e "${BOLD}${ICON_BRAND} SPACEHEATER${NC} - Scheduled Operations"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"

  local found=0
  while IFS=$'\t' read -r label repo count hour minute weekday plist_path; do
    found=1
    local schedule_desc
    schedule_desc=$(_describe_schedule "$hour" "$minute" "$weekday")

    echo -e "  ${CYAN}$repo${NC}"
    echo -e "    Target:   ${GREEN}$count${NC} HOT/WARM codespace(s)"
    echo -e "    Schedule: $schedule_desc"
    echo ""
  done < <(_launchd_list 2>/dev/null || true)

  if [ "$found" -eq 0 ]; then
    info "No schedules configured."
    info "Run 'spaceheater schedule set <count> --preset <name>' to create one."
  fi
}

cmd_schedule_remove() {
  if ! _is_macos; then
    error "Scheduling requires macOS (launchd). Cron support is planned for a future release."
  fi

  local target="${1:-}"
  local remove_all=false

  if [ "$target" = "--all" ]; then
    remove_all=true
  fi

  if [ "$remove_all" = "true" ]; then
    local removed=0
    while IFS=$'\t' read -r label repo count hour minute weekday plist_path; do
      _launchd_remove "$label" "$plist_path"
      removed=$((removed + 1))
    done < <(_launchd_list 2>/dev/null || true)

    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      jq -n \
        --arg action "schedule_remove" \
        --argjson removed "$removed" \
        '{
          action: $action,
          success: true,
          removed_count: $removed,
          timestamp: (now | todate)
        }'
    else
      if [ "$removed" -gt 0 ]; then
        success "Removed $removed schedule(s)"
      else
        info "No schedules to remove."
      fi
    fi
    return
  fi

  # Remove schedule for specific repo (default: current repo)
  local repo
  if [ -n "$target" ]; then
    repo="$target"
  else
    init_repo_config
    repo="$REPO"
  fi

  local label
  label=$(_schedule_label "$repo")
  local plist_path
  plist_path=$(_schedule_plist_path "$repo")

  if [ ! -f "$plist_path" ]; then
    if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
      output_json_error "schedule_remove" "No schedule found for $repo"
    else
      warn "No schedule found for $repo"
    fi
    return 1
  fi

  _launchd_remove "$label" "$plist_path"

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    jq -n \
      --arg action "schedule_remove" \
      --arg repo "$repo" \
      '{
        action: $action,
        success: true,
        repository: $repo,
        timestamp: (now | todate)
      }'
  else
    success "Removed schedule for $repo"
  fi
}

cmd_schedule_status() {
  if ! _is_macos; then
    error "Scheduling requires macOS (launchd). Cron support is planned for a future release."
  fi

  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    local json_array="[]"

    while IFS=$'\t' read -r label repo count hour minute weekday plist_path; do
      local schedule_desc
      schedule_desc=$(_describe_schedule "$hour" "$minute" "$weekday")

      local status_output
      status_output=$(_launchd_status "$label")
      local pid=""
      local exit_status=""
      IFS='|' read -r pid exit_status <<< "$status_output"

      json_array=$(echo "$json_array" | jq \
        --arg label "$label" \
        --arg repo "$repo" \
        --argjson count "$count" \
        --arg schedule "$schedule_desc" \
        --arg pid "$pid" \
        --arg exit_status "$exit_status" \
        '. += [{
          label: $label,
          repository: $repo,
          desired_count: $count,
          schedule: $schedule,
          pid: (if $pid != "" then ($pid | tonumber) else null end),
          last_exit_status: (if $exit_status != "" then ($exit_status | tonumber) else null end)
        }]')
    done < <(_launchd_list 2>/dev/null || true)

    local log_file
    log_file="$(_schedule_log_dir)/schedule.log"
    local recent_logs="null"
    if [ -f "$log_file" ]; then
      recent_logs=$(tail -5 "$log_file" 2>/dev/null | jq -Rs 'split("\n") | map(select(. != ""))' 2>/dev/null || echo "null")
    fi

    jq -n \
      --argjson schedules "$json_array" \
      --argjson recent_logs "$recent_logs" \
      '{
        action: "schedule_status",
        success: true,
        schedules: $schedules,
        count: ($schedules | length),
        recent_logs: $recent_logs,
        timestamp: (now | todate)
      }'
    return
  fi

  echo -e "${BOLD}${ICON_BRAND} SPACEHEATER${NC} - Schedule Status"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"

  local found=0
  while IFS=$'\t' read -r label repo count hour minute weekday plist_path; do
    found=1
    local schedule_desc
    schedule_desc=$(_describe_schedule "$hour" "$minute" "$weekday")

    local status_output
    status_output=$(_launchd_status "$label")
    local pid=""
    local exit_status=""
    IFS='|' read -r pid exit_status <<< "$status_output"

    echo -e "  ${CYAN}$repo${NC}"
    echo -e "    Target:   ${GREEN}$count${NC} HOT/WARM codespace(s)"
    echo -e "    Schedule: $schedule_desc"
    if [ -n "$pid" ]; then
      echo -e "    Status:   ${GREEN}Running${NC} (PID: $pid)"
    elif [ -n "$exit_status" ]; then
      if [ "$exit_status" = "0" ]; then
        echo -e "    Last run: ${GREEN}Success${NC} (exit: 0)"
      else
        echo -e "    Last run: ${RED}Failed${NC} (exit: $exit_status)"
      fi
    else
      echo -e "    Status:   ${DIM}Not loaded${NC}"
    fi
    echo ""
  done < <(_launchd_list 2>/dev/null || true)

  if [ "$found" -eq 0 ]; then
    info "No schedules configured."
    return
  fi

  # Show recent log entries
  local log_file
  log_file="$(_schedule_log_dir)/schedule.log"
  if [ -f "$log_file" ]; then
    echo -e "${BOLD}RECENT LOG${NC}"
    echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
    tail -10 "$log_file" 2>/dev/null || true
    echo ""
  fi
}

cmd_schedule_run() {
  local desired="${1:-}"

  if [ -z "$desired" ]; then
    error "Missing required argument: <desired_count>\nUsage: spaceheater schedule run <count>"
  fi

  if ! [[ "$desired" =~ ^[0-9]+$ ]] || [ "$desired" -lt 1 ] || [ "$desired" -gt 3 ]; then
    error "Count must be between 1 and 3"
  fi

  # Always use JSON mode internally for schedule runs
  OUTPUT_FORMAT="json"

  init_repo_config

  # Count existing HOT + WARM codespaces
  local existing
  existing=$(count_hot_warm_codespaces)

  local deficit=$((desired - existing))

  if [ "$deficit" -le 0 ]; then
    jq -n \
      --arg action "schedule_run" \
      --arg repo "$REPO" \
      --argjson desired "$desired" \
      --argjson existing "$existing" \
      '{
        action: $action,
        success: true,
        repository: $repo,
        desired_count: $desired,
        existing_hot_warm: $existing,
        created_count: 0,
        skipped: true,
        message: "Target already met",
        timestamp: (now | todate)
      }'
    return
  fi

  # Cap at 3
  if [ "$deficit" -gt 3 ]; then
    deficit=3
  fi

  # Create the deficit codespaces and capture the output
  local create_output
  create_output=$(cmd_create "$deficit" 2>&1) || true

  # Wrap cmd_create's JSON output with schedule_run context
  if echo "$create_output" | jq empty 2>/dev/null; then
    echo "$create_output" | jq \
      --arg action "schedule_run" \
      --arg repo "$REPO" \
      --argjson desired "$desired" \
      --argjson existing "$existing" \
      --argjson deficit "$deficit" \
      '{
        action: $action,
        success: .success,
        repository: $repo,
        desired_count: $desired,
        existing_hot_warm: $existing,
        created_count: .created_count,
        skipped: false,
        create_result: .,
        timestamp: (now | todate)
      }'
  else
    # cmd_create didn't produce valid JSON -- report what we can
    jq -n \
      --arg action "schedule_run" \
      --arg repo "$REPO" \
      --argjson desired "$desired" \
      --argjson existing "$existing" \
      --argjson deficit "$deficit" \
      --arg create_output "$create_output" \
      '{
        action: $action,
        success: false,
        repository: $repo,
        desired_count: $desired,
        existing_hot_warm: $existing,
        created_count: 0,
        skipped: false,
        error: $create_output,
        timestamp: (now | todate)
      }'
  fi
}

