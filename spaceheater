# Main
# ============================================================================
# MAIN ENTRY POINT & COMMAND DISPATCHER
# ============================================================================

main() {
  # Parse --config and --json flags before anything else
  local custom_config=""
  local -a args=()
  local expect_config_value=0
  OUTPUT_FORMAT=""  # Global variable for output format (empty or "json")

  for arg in "$@"; do
    if [ $expect_config_value -eq 1 ]; then
      custom_config="$arg"
      expect_config_value=0
    elif [[ "$arg" =~ ^--config= ]]; then
      custom_config="${arg#--config=}"
    elif [[ "$arg" == "--config" ]]; then
      expect_config_value=1
    elif [[ "$arg" == "--json" ]] || [[ "$arg" == "-j" ]]; then
      OUTPUT_FORMAT="json"
    elif [[ "$arg" =~ ^--output= ]]; then
      # Support --output=json format as well
      local output_value="${arg#--output=}"
      if [[ "$output_value" == "json" ]]; then
        OUTPUT_FORMAT="json"
      else
        error "Unknown output format: $output_value (supported: json)"
      fi
    else
      args+=("$arg")
    fi
  done

  if [ $expect_config_value -eq 1 ]; then
    error "Usage: --config=<file> or --config <file>"
  fi

  # Track which SPACEHEATER_* variables were set in the environment
  # before loading config files (these take highest precedence)
  for var in REPO BRANCH MACHINE RETENTION IDLE_TIMEOUT DEVCONTAINER_PATH DISPLAY_NAME LOCATION CONNECT DEBUG UI_STYLE SCHEDULE_LOG_DIR; do
    local env_var="SPACEHEATER_${var}"
    if [ -n "${!env_var:-}" ]; then
      ENV_VARS_SET="$ENV_VARS_SET $env_var"
    fi
  done

  # Load config files early (before check_dependencies to allow config to affect behavior)
  if [ -n "$custom_config" ]; then
    load_specific_config "$custom_config"
  else
    load_config_files
  fi

  # Initialize configuration variables from loaded config
  init_config_vars

  check_dependencies

  local cmd="${args[0]:-help}"
  unset 'args[0]'

  case "$cmd" in
    create)
      cmd_create "${args[@]}"
      ;;
    list|ls)
      cmd_list "${args[@]}"
      ;;
    start)
      cmd_start "${args[@]}"
      ;;
    autostart)
      cmd_autostart
      ;;
    stop)
      cmd_stop "${args[@]}"
      ;;
    clean)
      cmd_clean "${args[@]}"
      ;;
    delete|rm)
      cmd_delete "${args[@]}"
      ;;
    config)
      # Handle config subcommands
      local subcmd="${args[1]:-show}"
      case "$subcmd" in
        init)
          cmd_config_init "${args[2]:-}"
          ;;
        edit)
          cmd_config_edit
          ;;
        validate)
          validate_config_file "${args[2]:-}"
          ;;
        show|"")
          cmd_config
          ;;
        *)
          error "Unknown config subcommand: $subcmd\nValid subcommands: init, edit, validate, show"
          ;;
      esac
      ;;
    schedule)
      cmd_schedule "${args[@]}"
      ;;
    version|--version|-v)
      cmd_version
      ;;
    help|--help|-h)
      cmd_help
      ;;
    *)
      error "Unknown command: $cmd\nRun 'spaceheater help' for usage."
      ;;
  esac
}

main "$@"
