check_dependencies() {
  # Check for GitHub CLI
  if ! command -v gh &>/dev/null; then
    error "GitHub CLI (gh) is required. Install from: https://cli.github.com"
  fi

  # Check for jq
  if ! command -v jq &>/dev/null; then
    error "jq is required for JSON processing. Install from: https://jqlang.github.io/jq/"
  fi

  # Check for Python 3
  if ! command -v python3 &>/dev/null; then
    error "Python 3 is required for date calculations. Install from: https://python.org"
  fi

  # Check for git
  if ! command -v git &>/dev/null; then
    error "Git is required for repository detection"
  fi

  # Check GitHub authentication
  if ! gh auth status &>/dev/null; then
    error "Not authenticated with GitHub. Run: gh auth login"
  fi
}

