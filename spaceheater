#!/usr/bin/env bash
#
# spaceheater: Pre-create GitHub Codespaces for faster access
#
# Usage:
#   spaceheater create <count>    Create N pre-warmed codespaces
#   spaceheater list              List all codespaces with status
#   spaceheater start [name]      Start a codespace (fuzzy matching, no quotes needed)
#   spaceheater autostart         Auto-select and start a clean codespace
#   spaceheater stop [name]       Stop a running codespace
#   spaceheater clean [days]      Delete codespaces older than N days (default: 7)
#   spaceheater delete <name>     Delete a specific codespace
#   spaceheater config            Show current configuration
#   spaceheater config init       Create a config file template
#   spaceheater config edit       Edit your config file
#   spaceheater config validate   Validate config file syntax
#   spaceheater schedule set      Schedule automatic codespace pre-warming
#   spaceheater schedule list     List active schedules
#   spaceheater schedule remove   Remove a schedule
#   spaceheater schedule status   Show schedule status
#   spaceheater help              Show this help
#   spaceheater version           Show version information
#
# Options:
#   --config=<file>               Load configuration from a specific file

set -euo pipefail

# ============================================================================
# CONFIGURATION FILE SYSTEM
# ============================================================================

# Find all config files that exist (in order: system, user, repo)
find_config_files() {
  local -a config_files=()

  # System config
  if [ -f "/etc/spaceheater/config" ]; then
    config_files+=("/etc/spaceheater/config")
  fi

  # User config (XDG spec)
  local user_config="${XDG_CONFIG_HOME:-$HOME/.config}/spaceheater/config"
  if [ -f "$user_config" ]; then
    config_files+=("$user_config")
  fi

  # Repository config
  if [ -f ".spaceheater.conf" ]; then
    config_files+=(".spaceheater.conf")
  fi

  # Use conditional expansion to handle empty array with set -u
  printf '%s\n' "${config_files[@]+"${config_files[@]}"}"
}

# Track which variables were set by environment before config loading
# Using a space-separated string instead of associative array for bash 3 compatibility
ENV_VARS_SET=""

# Load a single config file
# Sets SPACEHEATER_* variables for keys not already set
load_config_file() {
  local config_file="$1"

  if [ ! -f "$config_file" ]; then
    return 0
  fi

  debug "Loading config file: $config_file"

  while IFS='=' read -r key value; do
    # Skip empty lines
    if [ -z "$key" ]; then
      continue
    fi

    # Skip comments
    if [[ "$key" =~ ^[[:space:]]*# ]]; then
      continue
    fi

    # Trim whitespace from key and value
    key=$(echo "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    value=$(echo "$value" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    # Skip if key or value is empty after trimming
    if [ -z "$key" ] || [ -z "$value" ]; then
      continue
    fi

    # Add SPACEHEATER_ prefix if not present
    if [[ ! "$key" =~ ^SPACEHEATER_ ]]; then
      key="SPACEHEATER_${key}"
    fi

    # Convert to uppercase
    key=$(echo "$key" | tr '[:lower:]' '[:upper:]')

    # Skip if this variable was set in the environment before config loading
    if [[ " $ENV_VARS_SET " =~ \ $key\  ]]; then
      debug "  Skipped $key (set by environment)"
      continue
    fi

    # Always set the value (later config files override earlier ones)
    export "$key=$value"
    debug "  Set $key=$value"
  done < "$config_file"
}

# Load configuration from all config files
load_config_files() {
  local -a config_files
  # Use while read instead of mapfile for bash 3 compatibility
  while IFS= read -r line; do
    config_files+=("$line")
  done < <(find_config_files)

  # Use conditional expansion to handle empty array with set -u
  for config_file in "${config_files[@]+"${config_files[@]}"}"; do
    load_config_file "$config_file"
    if [ -z "$LOADED_CONFIG_FILES" ]; then
      LOADED_CONFIG_FILES="$config_file"
    else
      LOADED_CONFIG_FILES="$LOADED_CONFIG_FILES"$'\n'"$config_file"
    fi
  done
}

# Load a specific config file (for --config flag)
load_specific_config() {
  local config_file="$1"

  if [ ! -f "$config_file" ]; then
    error "Config file not found: $config_file"
  fi

  debug "Loading specific config file: $config_file"
  load_config_file "$config_file"
  LOADED_CONFIG_FILES="$config_file (via --config)"
}

# Validate a config file (for validate subcommand)
validate_config_file() {
  local config_file="${1:-.spaceheater.conf}"

  if [ ! -f "$config_file" ]; then
    error "Config file not found: $config_file"
  fi

  local line_num=0
  local errors=0
  local warnings=0

  info "Validating config file: $config_file"
  echo

  # Valid config keys (without SPACEHEATER_ prefix)
  local valid_keys="REPO BRANCH MACHINE RETENTION IDLE_TIMEOUT DEVCONTAINER_PATH DISPLAY_NAME LOCATION CONNECT DEBUG UI_STYLE"

  while IFS='=' read -r key value; do
    line_num=$((line_num + 1))

    # Skip empty lines
    if [ -z "$key" ]; then
      continue
    fi

    # Skip comments
    if [[ "$key" =~ ^[[:space:]]*# ]]; then
      continue
    fi

    # Trim whitespace
    key=$(echo "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    value=$(echo "$value" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    # Check for empty key or value
    if [ -z "$key" ]; then
      continue
    fi

    if [ -z "$value" ]; then
      warn "Line $line_num: Empty value for key '$key'"
      warnings=$((warnings + 1))
      continue
    fi

    # Remove SPACEHEATER_ prefix if present for validation
    local check_key="$key"
    if [[ "$check_key" =~ ^SPACEHEATER_ ]]; then
      check_key="${check_key#SPACEHEATER_}"
    fi

    # Convert to uppercase for checking
    check_key=$(echo "$check_key" | tr '[:lower:]' '[:upper:]')

    # Check if key is valid
    if [[ ! " $valid_keys " =~ \ $check_key\  ]]; then
      error_msg="Line $line_num: Unknown configuration key '$key'"
      echo -e "${RED}${ICON_ERROR} $error_msg${NC}"
      errors=$((errors + 1))
    else
      echo -e "${GREEN}${ICON_CHECK}${NC} Line $line_num: $key=$value"
    fi
  done < "$config_file"

  echo
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    success "Config file is valid!"
    return 0
  elif [ "$errors" -eq 0 ]; then
    warn "Config file is valid with $warnings warning(s)"
    return 0
  else
    error "Config file has $errors error(s) and $warnings warning(s)"
  fi
}

