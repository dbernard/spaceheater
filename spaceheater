  echo -e "\n${DIM}────────────────────────────────────────────────────────────────${NC}"
  echo -e "${BOLD}${ICON_INFO} Configuration Philosophy:${NC}"
  echo -e "  Spaceheater respects your repository's devcontainer and GitHub's defaults."
  echo -e "  Only set environment variables when you need to override these defaults."
  echo ""
  echo -e "${BOLD}${ICON_NEXT} Available Commands:${NC}"
  echo -e "  ${CYAN}spaceheater config init${NC}      Create a config file template"
  echo -e "  ${CYAN}spaceheater config edit${NC}      Edit your config file"
  echo -e "  ${CYAN}spaceheater config validate${NC}  Validate config file syntax"
  echo ""
  echo -e "${BOLD}${ICON_NEXT} Configuration Precedence (highest to lowest):${NC}"
  echo -e "  ${DIM}1. CLI arguments${NC}"
  echo -e "  ${DIM}2. Environment variables (SPACEHEATER_*)${NC}"
  echo -e "  ${DIM}3. Repository config (.spaceheater.conf)${NC}"
  echo -e "  ${DIM}4. User config (~/.config/spaceheater/config)${NC}"
  echo -e "  ${DIM}5. System config (/etc/spaceheater/config)${NC}"
  echo -e "  ${DIM}6. Built-in defaults${NC}"
}

