cmd_version() {
  if [ "${OUTPUT_FORMAT:-}" = "json" ]; then
    # Get git commit hash if available
    local git_commit=""
    if git rev-parse HEAD &>/dev/null 2>&1; then
      git_commit=$(git rev-parse --short HEAD 2>/dev/null || echo "")
    fi

    # Get system information
    local os_type
    os_type=$(uname -s)
    local os_version
    os_version=$(uname -r)
    local platform
    platform=$(uname -m)
    local bash_version="${BASH_VERSION}"

    # Output JSON
    jq -n \
      --arg version "$VERSION" \
      --arg git_commit "$git_commit" \
      --arg os_type "$os_type" \
      --arg os_version "$os_version" \
      --arg platform "$platform" \
      --arg bash_version "$bash_version" \
      --arg project_url "https://github.com/dbernard/spaceheater" \
      --arg license "MIT" \
      '{
        version: $version,
        git_commit: (if $git_commit != "" then $git_commit else null end),
        system: {
          os_type: $os_type,
          os_version: $os_version,
          platform: $platform,
          bash_version: $bash_version
        },
        project: {
          url: $project_url,
          license: $license
        },
        timestamp: (now | todate)
      }'
  else
    echo -e "${BOLD}${ICON_BRAND} SPACEHEATER${NC} version ${CYAN}$VERSION${NC}"
    echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"
    echo -e "A tool for pre-creating fully-built GitHub Codespaces that are ready for instant startup."
    echo ""
    echo -e "${ICON_REPO} Project: ${CYAN}https://github.com/dbernard/spaceheater${NC}"
    echo -e "${ICON_CALENDAR} License: ${CYAN}MIT${NC}"
  fi
}

