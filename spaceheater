# Main
# ============================================================================
# MAIN ENTRY POINT & COMMAND DISPATCHER
# ============================================================================

main() {
  check_dependencies

  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    create)
      cmd_create "$@"
      ;;
    list|ls)
      cmd_list "$@"
      ;;
    start)
      cmd_start "$@"
      ;;
    autostart)
      cmd_autostart
      ;;
    stop)
      cmd_stop "$@"
      ;;
    clean)
      cmd_clean "$@"
      ;;
    delete|rm)
      cmd_delete "$@"
      ;;
    config)
      cmd_config
      ;;
    version|--version|-v)
      cmd_version
      ;;
    help|--help|-h)
      cmd_help
      ;;
    *)
      error "Unknown command: $cmd\nRun 'spaceheater help' for usage."
      ;;
  esac
}

main "$@"
