# Get repository ID with caching
get_repo_id() {
  if [ -z "$CACHED_REPO_ID" ]; then
    CACHED_REPO_ID=$(gh api "/repos/$REPO" --jq .id 2>/dev/null)
    if [ -z "$CACHED_REPO_ID" ]; then
      error "Failed to get repository ID for $REPO"
    fi
    debug "Cached repository ID: $CACHED_REPO_ID"
  fi
  echo "$CACHED_REPO_ID"
}

# Validate machine type against GitHub's allowed values
validate_machine_type() {
  local machine="$1"
  local valid_types="basicLinux32gb basicLinux standardLinux standardLinux32gb premiumLinux premiumLinux32gb largePremiumLinux"

  if [[ ! " $valid_types " =~ \ $machine\  ]]; then
    warn "Warning: '$machine' may not be a valid machine type"
    warn "Valid types: basicLinux32gb, standardLinux, premiumLinux, largePremiumLinux, etc."
    read -p "Continue anyway? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      exit 1
    fi
  fi
}

# ============================================================================
# REPOSITORY CONFIGURATION
# ============================================================================

# Get default machine type for the repository
get_default_machine() {
  local default_machine=""

  # Try to get the first available machine type from the API
  default_machine=$(get_available_machines --jq '.machines[0].name' 2>/dev/null)

  if [ -z "$default_machine" ]; then
    # API call failed or no machines available
    # Check if it's an API error vs no machines
    local api_response
    api_response=$(get_available_machines 2>&1) || true
    if [[ "$api_response" == *"machines"* ]]; then
      # API worked but no machines available
      error "No machine types available for repository $REPO.\n\nPlease contact your repository administrator to enable Codespaces."
    else
      # API call failed - can't determine available machines
      error "Unable to detect available machine types for $REPO.\n\nPlease set SPACEHEATER_MACHINE environment variable explicitly.\nExample: export SPACEHEATER_MACHINE=basicLinux32gb\n\nCommon machine types:\n  - basicLinux32gb (2 cores, 8 GB RAM)\n  - standardLinux (4 cores, 16 GB RAM)\n  - premiumLinux (8 cores, 32 GB RAM)"
    fi
  fi

  debug "Detected default machine type: $default_machine"
  echo "$default_machine"
}

# Auto-detect repository from current directory
detect_repo() {
  # First check environment variable
  if [ -n "${SPACEHEATER_REPO:-}" ]; then
    echo "$SPACEHEATER_REPO"
    return 0
  fi

  # Try to detect from current git repository
  if git rev-parse --git-dir &>/dev/null 2>&1; then
    local repo
    repo="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")"
    if [ -n "$repo" ]; then
      echo "$repo"
      return 0
    fi
  fi

  # No repo found
  return 1
}

# Detect default branch for the repository
detect_default_branch() {
  if [ -n "${SPACEHEATER_BRANCH:-}" ]; then
    echo "$SPACEHEATER_BRANCH"
    return 0
  fi

  # Try to get default branch from GitHub API
  local default_branch
  default_branch="$(gh api "/repos/$REPO" --jq .default_branch 2>/dev/null || echo "")"
  if [ -n "$default_branch" ]; then
    echo "$default_branch"
    return 0
  fi

  # Fallback to common defaults
  echo "main"
}

# Initialize repo configuration (called when needed, not at startup)
init_repo_config() {
  if [ -z "${REPO:-}" ]; then
    REPO=$(detect_repo) || {
      error "Unable to detect repository.\n\nPlease set SPACEHEATER_REPO environment variable:\n  export SPACEHEATER_REPO=owner/repo\n\nOr run this command from within a git repository."
    }
  fi

  if [ -z "${BRANCH:-}" ]; then
    BRANCH=$(detect_default_branch)
  fi

  debug "Repository: $REPO, Branch: $BRANCH"
}

# Initialize configuration variables from environment
# This function is called after config files are loaded
init_config_vars() {
  # Configuration (only set for help command, others will call init_repo_config)
  REPO="${SPACEHEATER_REPO:-${REPO:-}}"
  BRANCH="${SPACEHEATER_BRANCH:-${BRANCH:-}}"

  # Optional overrides - only pass to GitHub if explicitly set by user
  MACHINE="${SPACEHEATER_MACHINE:-}"
  RETENTION="${SPACEHEATER_RETENTION:-}"
  IDLE_TIMEOUT="${SPACEHEATER_IDLE_TIMEOUT:-}"
  DEVCONTAINER_PATH="${SPACEHEATER_DEVCONTAINER_PATH:-}"
  DISPLAY_NAME="${SPACEHEATER_DISPLAY_NAME:-}"
  LOCATION="${SPACEHEATER_LOCATION:-}"

  # Connection method: browser, ssh, or code (VS Code)
  CONNECT_METHOD="${SPACEHEATER_CONNECT:-browser}"

  # Debug mode
  DEBUG="${SPACEHEATER_DEBUG:-false}"

  # Schedule log directory
  SPACEHEATER_SCHEDULE_LOG_DIR="${SPACEHEATER_SCHEDULE_LOG_DIR:-}"
}

