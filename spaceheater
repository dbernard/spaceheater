  echo -e "  ${ICON_REGION} SPACEHEATER_LOCATION:          ${CYAN}${LOCATION:-<auto-detect closest region>}${NC}"
  echo -e "  ${ICON_CALENDAR} SPACEHEATER_DISPLAY_NAME:      ${CYAN}${DISPLAY_NAME:-<GitHub-generated>}${NC}"
  echo ""

  echo -e "${BOLD}Debug Settings:${NC}"
  echo -e "  ${ICON_INFO} SPACEHEATER_DEBUG:             ${CYAN}${DEBUG:-false}${NC}"
  echo ""

  echo -e "${BOLD}Current Detection:${NC}"

  # Try to detect and show current values
  if detect_repo &>/dev/null; then
    local detected_repo=$(detect_repo)
    echo -e "  ${ICON_CHECK} Detected Repository:           ${GREEN}$detected_repo${NC}"
    echo -e "  ${ICON_CHECK} Detected Branch:               ${GREEN}$(detect_default_branch)${NC}"

    # Try to show devcontainer info if we're in the repo
    if [ -f ".devcontainer/devcontainer.json" ]; then
      echo -e "  ${ICON_CHECK} Devcontainer:                  ${GREEN}.devcontainer/devcontainer.json (found)${NC}"

      # Try to extract hostRequirements if jq is available
      if command -v jq &>/dev/null; then
        local cpus=$(jq -r '.hostRequirements.cpus // empty' .devcontainer/devcontainer.json 2>/dev/null)
        local memory=$(jq -r '.hostRequirements.memory // empty' .devcontainer/devcontainer.json 2>/dev/null)
        if [ -n "$cpus" ] || [ -n "$memory" ]; then
          echo -e "  ${ICON_CHECK} Devcontainer Requirements:     ${GREEN}${cpus:+$cpus cores}${cpus:+, }${memory:+$memory RAM}${NC}"
        fi
      fi
    elif [ -f ".devcontainer.json" ]; then
      echo -e "  ${ICON_CHECK} Devcontainer:                  ${GREEN}.devcontainer.json (found)${NC}"
    else
      echo -e "  ${ICON_INFO} Devcontainer:                  ${DIM}<none - will use GitHub default image>${NC}"
    fi
  else
    echo -e "  ${ICON_CROSS} Detected Repository:           ${DIM}<none - not in a git repo>${NC}"
  fi

  echo -e "\n${DIM}────────────────────────────────────────────────────────────────${NC}"
  echo -e "${BOLD}${ICON_INFO} Configuration Philosophy:${NC}"
  echo -e "  Spaceheater respects your repository's devcontainer and GitHub's defaults."
  echo -e "  Only set environment variables when you need to override these defaults."
  echo ""
  echo -e "${BOLD}${ICON_NEXT} To override a setting:${NC}"
  echo -e "  ${DIM}export SPACEHEATER_MACHINE=premiumLinux${NC}"
  echo -e "  ${DIM}export SPACEHEATER_RETENTION=168h${NC}"
}

