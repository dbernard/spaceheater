# Date calculation helper functions
calculate_age_days() {
  local created_at="$1"
  python3 -c "
from datetime import datetime, timezone
created = datetime.fromisoformat('$created_at'.replace('Z', '+00:00'))
now = datetime.now(timezone.utc)
delta = now - created
print(delta.days)
" 2>/dev/null || echo "999"
}

format_time_ago() {
  local created_at="$1"
  python3 -c "
from datetime import datetime, timezone
created = datetime.fromisoformat('$created_at'.replace('Z', '+00:00'))
now = datetime.now(timezone.utc)
delta = now - created
days = delta.days
hours = delta.seconds // 3600
if days > 0:
    print(f'{days}d {hours}h ago')
else:
    print(f'{hours}h ago')
" 2>/dev/null || echo ""
}

# GitHub API wrapper functions
get_all_codespaces() {
  gh api "/user/codespaces?repository_id=$(get_repo_id)" "$@"
}

get_codespaces_with_jq() {
  local jq_filter="$1"
  get_all_codespaces --jq "$jq_filter"
}

get_available_machines() {
  gh api "/repos/$REPO/codespaces/machines" "$@"
}

find_codespace_by_pattern() {
  local search_term="$1"
  get_codespaces_with_jq '.codespaces | .[] | "\(.name)\t\(.display_name // .name)"' | \
    grep -i "$search_term" || true
}

# Interactive selection helper
# Returns the selected codespace name via echo
# Usage: codespace_name=$(select_codespace_interactive "$matches" "$search_term")
select_codespace_interactive() {
  local matches="$1"
  local search_term="$2"
  local codespace_name=""

  # Check if matches is empty
  if [ -z "$matches" ]; then
    error "No codespace found matching: $search_term"
  fi

  # Count matches
  local match_count=$(echo "$matches" | wc -l | tr -d ' ')

  if [ "$match_count" -eq 1 ]; then
    # Single match - use it
    codespace_name=$(echo "$matches" | cut -f1)
    local display_name=$(echo "$matches" | cut -f2)
    debug "Found match: $display_name"
  else
    # Multiple matches - let user select interactively
    info "Multiple codespaces match '$search_term':"
    echo >&2

    # Build arrays for selection
    local -a display_names=()
    local -a codespace_names=()
    while IFS=$'\t' read -r name display; do
      codespace_names+=("$name")
      display_names+=("$display")
    done <<< "$matches"

    # Interactive selection
    PS3="Select codespace number: "
    select display_name in "${display_names[@]}"; do
      if [ -n "$display_name" ]; then
        local index=$((REPLY - 1))
        codespace_name="${codespace_names[$index]}"
        debug "Selected: $display_name"
        break
      else
        echo "Invalid selection. Please try again." >&2
      fi
    done
  fi

  echo "$codespace_name"
}

# ============================================================================
# DEPENDENCY CHECKS & INITIALIZATION
# ============================================================================

check_dependencies() {
  # Check for GitHub CLI
  if ! command -v gh &>/dev/null; then
    error "GitHub CLI (gh) is required. Install from: https://cli.github.com"
  fi

  # Check for jq
  if ! command -v jq &>/dev/null; then
    error "jq is required for JSON processing. Install from: https://jqlang.github.io/jq/"
  fi

  # Check for Python 3
  if ! command -v python3 &>/dev/null; then
    error "Python 3 is required for date calculations. Install from: https://python.org"
  fi

  # Check for git
  if ! command -v git &>/dev/null; then
    error "Git is required for repository detection"
  fi

  # Check GitHub authentication
  if ! gh auth status &>/dev/null; then
    error "Not authenticated with GitHub. Run: gh auth login"
  fi
}

# ============================================================================
# COMMAND IMPLEMENTATIONS
# ============================================================================

cmd_create() {
  init_repo_config
  local count="${1:-1}"

  if ! [[ "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ]; then
    error "Count must be a positive integer"
  fi

  # Cap at 3 codespaces per invocation
  if [ "$count" -gt 3 ]; then
    warn "Limiting to 3 codespaces per invocation (requested: $count)"
    count=3
  fi

  info "Creating $count codespace(s) for $REPO (branch: $BRANCH)..."

  # Determine machine type to use
  local effective_machine="$MACHINE"
  if [ -z "$effective_machine" ]; then
    # No machine specified, try to detect default
    info "  Detecting default machine type..."
    effective_machine=$(get_default_machine)
    info "  Machine type: $effective_machine (auto-detected)"
  else
    info "  Machine type: $effective_machine (user-specified)"
    validate_machine_type "$effective_machine"
  fi

  if [ -n "$RETENTION" ]; then
    info "  Retention: $RETENTION (user-specified)"
  fi

  if [ -n "$IDLE_TIMEOUT" ]; then
    info "  Idle timeout: $IDLE_TIMEOUT (user-specified)"
  fi

  if [ -n "$DEVCONTAINER_PATH" ]; then
    info "  Devcontainer: $DEVCONTAINER_PATH (user-specified)"
  fi

  if [ -n "$LOCATION" ]; then
    info "  Region: $LOCATION (user-specified)"
  fi

  echo

  local created=0
  local failed=0

  for i in $(seq 1 "$count"); do
    info "[$i/$count] Creating codespace..."

    debug "Creating codespace with: repo=$REPO branch=$BRANCH machine=$effective_machine"

    # Build args array with only explicitly set values
    local create_args=(
      --repo "$REPO"
      --branch "$BRANCH"
      --default-permissions
      --machine "$effective_machine"  # Always pass machine to prevent interactive prompts
    )

    if [ -n "$RETENTION" ]; then
      create_args+=(--retention-period "$RETENTION")
    fi

    if [ -n "$IDLE_TIMEOUT" ]; then
      create_args+=(--idle-timeout "$IDLE_TIMEOUT")
    fi

    if [ -n "$DEVCONTAINER_PATH" ]; then
      create_args+=(--devcontainer-path "$DEVCONTAINER_PATH")
    fi

    if [ -n "$LOCATION" ]; then
      create_args+=(--location "$LOCATION")
    fi

    if [ -n "$DISPLAY_NAME" ]; then
      # Append counter for uniqueness
      create_args+=(--display-name "${DISPLAY_NAME}-${i}")
    fi

    # Capture the output which contains the codespace name
    local output="$(gh codespace create "${create_args[@]}" 2>&1)"

    # Extract codespace name from output (last line is the codespace name)
    local codespace_name=$(echo "$output" | tail -1 | grep -E '^[a-z0-9]+-[a-z0-9]+-[a-z0-9-]+$' || echo "")

    if [ -n "$codespace_name" ]; then
      success "  ${ICON_CHECK} Created: $codespace_name"
      created=$((created + 1))
    else
      warn "  ${ICON_CROSS} Failed to create codespace"
      echo "  Output: $output"
      failed=$((failed + 1))
    fi

    # Rate limit protection
    if [ "$i" -lt "$count" ]; then
      sleep 2
    fi
  done

  echo
  success "Created $created codespace(s)"
  if [ "$failed" -gt 0 ]; then
    warn "Failed: $failed"
  fi

  info "\nCodespaces will fully build in the background (~5-10 minutes)"
  info "They'll auto-stop after idle timeout and be ready for instant start"
  info "\nRun 'spaceheater list' to see your codespaces"
  info "Run 'spaceheater start' to connect to one when ready"
}

cmd_list() {
  init_repo_config
  echo -e "${BOLD}${ICON_BRAND} SPACEHEATER${NC} - Codespaces for ${CYAN}$REPO${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}\n"

  # Arrays to hold categorized codespaces
  local -a hot_lines=()
  local -a warm_lines=()
  local -a transitioning_lines=()
  local -a cold_lines=()

  # Collect and categorize codespaces
  while IFS=$'\t' read -r state display_name branch has_uncommitted has_unpushed ahead behind name created_at; do
    # Calculate age in days for WARM/COLD determination
    local age_days=$(calculate_age_days "$created_at")

    # Determine git cleanliness (clean = no uncommitted, no ahead, optionally behind is OK)
    local is_git_clean=false
    if [ "$has_uncommitted" != "true" ] && [ "$has_unpushed" != "true" ] && [ "$ahead" -eq 0 ]; then
      is_git_clean=true
    fi

    # Categorize by temperature
    local category=""
    case "$state" in
      Available)
        category="HOT"
        ;;
      Shutdown)
        # WARM = shutdown + clean git + recent (≤3 days)
        # COLD = shutdown + (dirty git OR old)
        if [ "$is_git_clean" = "true" ] && [ "$age_days" -le 3 ]; then
          category="WARM"
        else
          category="COLD"
        fi
        ;;
      Starting|Provisioning|ShuttingDown|Stopping)
        category="TRANSITIONING"
        ;;
      *)
        category="COLD"
        ;;
    esac

    # Determine git status indicator (dimmed for COLD codespaces)
    local git_indicator=""
    if [ "$category" = "COLD" ]; then
      # Dimmed indicators for cold codespaces
      if [ "$has_uncommitted" = "true" ] || [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
        git_indicator="${DIM}${RED}${ICON_DIRTY}${NC}"  # Dirty (has changes)
      elif [ "$behind" -gt 0 ]; then
        git_indicator="${DIM}${YELLOW}${ICON_BEHIND}${NC}"  # Behind remote
      else
        git_indicator="${DIM}${GREEN}${ICON_CLEAN}${NC}"  # Clean
      fi
    else
      # Normal indicators for hot/warm codespaces
      if [ "$has_uncommitted" = "true" ] || [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
        git_indicator="${RED}${ICON_DIRTY}${NC}"  # Dirty (has changes)
      elif [ "$behind" -gt 0 ]; then
        git_indicator="${YELLOW}${ICON_BEHIND}${NC}"  # Behind remote
      else
        git_indicator="${GREEN}${ICON_CLEAN}${NC}"  # Clean
      fi
    fi

    # Build git status details
    local git_details=""
    if [ "$has_uncommitted" = "true" ]; then
      git_details="${git_details}uncommitted"
    fi
    if [ "$has_unpushed" = "true" ] || [ "$ahead" -gt 0 ]; then
      if [ -n "$git_details" ]; then git_details="${git_details}, "; fi
      git_details="${git_details}${ahead}${ICON_ARROW_UP}"
    fi
    if [ "$behind" -gt 0 ]; then
      if [ -n "$git_details" ]; then git_details="${git_details}, "; fi
      git_details="${git_details}${behind}${ICON_ARROW_DOWN}"
    fi
    if [ -z "$git_details" ]; then
      git_details="clean"
    fi

    local age=$(format_time_ago "$created_at")

    # Format the line (with dimmed text for COLD, state info for TRANSITIONING)
    local line=""
    if [ "$category" = "TRANSITIONING" ]; then
      # For transitioning codespaces, show the state instead of git details
      local state_display=""
      case "$state" in
        Starting) state_display="Starting up" ;;
        Provisioning) state_display="Provisioning" ;;
        ShuttingDown) state_display="Shutting down" ;;
        Stopping) state_display="Stopping" ;;
        *) state_display="$state" ;;
      esac
      line="${git_indicator}\t${display_name}\t${branch}\t[${state_display}]\t${DIM}(${age})${NC}"
    elif [ "$category" = "COLD" ]; then
      line="${git_indicator}\t${DIM}${display_name}\t${branch}\t[${git_details}]\t(${age})${NC}"
    else
      line="${git_indicator}\t${display_name}\t${branch}\t[${git_details}]\t${DIM}(${age})${NC}"
    fi

    # Add to appropriate array
    case "$category" in
      HOT)
        hot_lines+=("$line")
        ;;
      WARM)
        warm_lines+=("$line")
        ;;
      TRANSITIONING)
        transitioning_lines+=("$line")
        ;;
      COLD)
        cold_lines+=("$line")
        ;;
    esac
  done < <(get_codespaces_with_jq '.codespaces | sort_by(.created_at) | reverse | .[] |
      "\(.state)\t\(.display_name // .name)\t\(.git_status.ref // "unknown")\t\(.git_status.has_uncommitted_changes // false)\t\(.git_status.has_unpushed_changes // false)\t\(.git_status.ahead // 0)\t\(.git_status.behind // 0)\t\(.name)\t\(.created_at)"')

  # Display HOT section
  echo -e "${COLOR_HOT}${ICON_HOT} HOT${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#hot_lines[@]} -gt 0 ]; then
    printf '%b\n' "${hot_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No hot codespaces. Start one with 'spaceheater start'${NC}"
  fi
  echo

  # Display WARM section
  echo -e "${COLOR_WARM}${ICON_WARM} WARM${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#warm_lines[@]} -gt 0 ]; then
    printf '%b\n' "${warm_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No warm codespaces. Create with 'spaceheater create [number]'${NC}"
  fi
  echo

  # Display TRANSITIONING section (only if there are transitioning codespaces)
  if [ ${#transitioning_lines[@]} -gt 0 ]; then
    echo -e "${COLOR_HEATING}${ICON_HEATING} TRANSITIONING${NC}"
    echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
    printf '%b\n' "${transitioning_lines[@]}" | column -t -s $'\t'
    echo
  fi

  # Display COLD section
  echo -e "${COLOR_COLD}${ICON_COLD} COLD${NC}"
  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  if [ ${#cold_lines[@]} -gt 0 ]; then
    printf '%b\n' "${cold_lines[@]}" | column -t -s $'\t'
  else
    echo -e "${DIM}No cold codespaces${NC}"
  fi
  echo

  echo -e "${DIM}────────────────────────────────────────────────────────────────${NC}"
  echo -e "${DIM}Git: ${GREEN}${ICON_CLEAN}${DIM}=Clean ${RED}${ICON_DIRTY}${DIM}=Has changes ${YELLOW}${ICON_BEHIND}${DIM}=Behind remote${NC}"
}

# Auto-select a clean codespace
auto_select_codespace() {
  local codespace_name=""

  # First try: Clean HOT codespaces (Available - immediately ready, no startup needed)
  codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Available" and
      (.git_status.has_uncommitted_changes // false) == false and
      (.git_status.has_unpushed_changes // false) == false and
      (.git_status.ahead // 0) == 0)) |
      sort_by(.created_at) | reverse | .[0].name // empty')

  if [ -z "$codespace_name" ]; then
    # Second try: Clean WARM codespaces (Shutdown - fully built but needs restart)
    codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Shutdown" and
        (.git_status.has_uncommitted_changes // false) == false and
        (.git_status.has_unpushed_changes // false) == false and
        (.git_status.ahead // 0) == 0)) |
        sort_by(.created_at) | reverse | .[0].name // empty')
  fi

  if [ -z "$codespace_name" ]; then
    error "No clean codespaces available.\n\nAutostart requires a codespace with no uncommitted changes.\nUse 'spaceheater start' for interactive selection or 'spaceheater create' to create new codespaces."
  fi

  echo "$codespace_name"
}

cmd_start() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater start organic sniffle" works without quotes
  local search_term="${*}"

  # Build command arguments
  local -a cmd_args=()
  local codespace_name=""

  # If search term provided, try to find matching codespace
  if [ -n "$search_term" ]; then
    debug "Searching for codespace matching: $search_term"

    # Fetch all codespaces with their names and display names
    local matches=$(find_codespace_by_pattern "$search_term")

    # Use interactive selection helper
    codespace_name=$(select_codespace_interactive "$matches" "$search_term")

    cmd_args+=(-c "$codespace_name")
  else
    info "Select a codespace to start..." >&2
  fi

  # Connect based on configured method
  # If no codespace name provided, gh will show its interactive menu
  case "$CONNECT_METHOD" in
    browser|web)
      gh codespace code --web "${cmd_args[@]}"
      ;;
    ssh)
      gh codespace ssh "${cmd_args[@]}"
      ;;
    code|vscode)
      gh codespace code "${cmd_args[@]}"
      ;;
    *)
      error "Unknown connection method: $CONNECT_METHOD\nValid options: browser, ssh, code"
      ;;
  esac
}

cmd_autostart() {
  init_repo_config

  info "Finding a clean codespace to start..."

  # Auto-select the best clean codespace
  local codespace_name=$(auto_select_codespace)

  debug "Selected codespace: $codespace_name"
  local display_name="$(gh codespace view -c "$codespace_name" --json displayName -q .displayName)"
  info "Starting codespace: ${display_name:-$codespace_name}..."

  # Connect based on configured method
  case "$CONNECT_METHOD" in
    browser|web)
      info "Opening in browser..."
      gh codespace code --web -c "$codespace_name"
      ;;
    ssh)
      info "Connecting via SSH..."
      gh codespace ssh -c "$codespace_name"
      ;;
    code|vscode)
      info "Opening in VS Code..."
      gh codespace code -c "$codespace_name"
      ;;
    *)
      error "Unknown connection method: $CONNECT_METHOD\nValid options: browser, ssh, code"
      ;;
  esac
}

cmd_stop() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater stop stunning lamp" works without quotes
  local search_term="${*}"

  # Special case: stop all running codespaces
  if [ "$search_term" = "all" ]; then
    info "Finding all running codespaces to stop..."

    # Get all running codespaces
    local running_codespaces=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Available")) | .[] | "\(.name)\t\(.display_name // .name)"')

    if [ -z "$running_codespaces" ]; then
      info "No running codespaces found"
      return 0
    fi

    # Count how many we're stopping
    local count=$(echo "$running_codespaces" | wc -l | tr -d ' ')
    info "Found $count running codespace(s)"
    echo

    # Stop each codespace
    local stopped=0
    local failed=0
    while IFS=$'\t' read -r name display_name; do
      info "Stopping: $display_name"
      if gh codespace stop -c "$name" 2>/dev/null; then
        success "  ${ICON_CHECK} Stopped"
        stopped=$((stopped + 1))
      else
        warn "  ${ICON_CROSS} Failed to stop"
        failed=$((failed + 1))
      fi
    done <<< "$running_codespaces"

    echo
    success "Stopped $stopped codespace(s)"
    if [ "$failed" -gt 0 ]; then
      warn "Failed: $failed"
    fi
    return 0
  fi

  if [ -z "$search_term" ]; then
    info "Finding running codespace to stop..."

    # Get the most recently used running codespace
    local codespace_name=$(get_codespaces_with_jq '.codespaces | map(select(.state == "Available")) |
             sort_by(.last_used_at // .created_at) | reverse | .[0].name // empty')

    if [ -z "$codespace_name" ]; then
      error "No running codespaces found"
    fi
  else
    # Search for matching codespace (similar to start command)
    debug "Searching for codespace matching: $search_term"

    # Fetch all codespaces with their names and display names
    local matches=$(find_codespace_by_pattern "$search_term")

    # Use interactive selection helper
    codespace_name=$(select_codespace_interactive "$matches" "$search_term")
  fi

  local display_name="$(gh codespace view -c "$codespace_name" --json displayName -q .displayName 2>/dev/null)"
  info "Stopping codespace: ${display_name:-$codespace_name}..."

  if gh codespace stop -c "$codespace_name"; then
    success "Stopped successfully!"
  else
    error "Failed to stop codespace"
  fi
}

cmd_clean() {
  init_repo_config
  local days="${1:-7}"

  if ! [[ "$days" =~ ^[0-9]+$ ]]; then
    error "Days must be a positive integer"
  fi

  info "Finding codespaces older than $days days in $REPO..."

  local cutoff_date=$(python3 -c "
from datetime import datetime, timedelta, timezone
cutoff = datetime.now(timezone.utc) - timedelta(days=$days)
print(cutoff.strftime('%Y-%m-%dT%H:%M:%SZ'))
")

  local to_delete=$(get_all_codespaces | jq -r --arg cutoff "$cutoff_date" '
      .codespaces |
      map(select(.created_at < $cutoff)) |
      .[] | "\(.name)\t\(.display_name // .name)\t\(.created_at)"')

  if [ -z "$to_delete" ]; then
    success "No codespaces older than $days days found."
    return 0
  fi

  echo "$to_delete" | while IFS=$'\t' read -r name display_name created_at; do
    echo -e "  - $display_name (created: $created_at)"
  done

  echo
  read -p "Delete these codespaces? [y/N] " -n 1 -r
  echo

  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    info "Cancelled."
    return 0
  fi

  echo "$to_delete" | while IFS=$'\t' read -r name display_name created_at; do
    info "Deleting: $display_name"
    if gh codespace delete -c "$name" --force; then
      success "  ${ICON_CHECK} Deleted"
    else
      warn "  ${ICON_CROSS} Failed to delete"
    fi
  done

  success "Cleanup complete!"
}

cmd_delete() {
  init_repo_config
  # Join all arguments to support names with spaces without escaping
  # e.g., "spaceheater delete stunning lamp" works without quotes
  local search_term="${*}"

  if [ -z "$search_term" ]; then
    error "Usage: spaceheater delete <codespace-name>"
  fi

  # Search for matching codespace (similar to start/stop commands)
  debug "Searching for codespace matching: $search_term"

  # Fetch all codespaces with their names and display names
  local matches=$(find_codespace_by_pattern "$search_term")

  # Use interactive selection helper
  local codespace_name=$(select_codespace_interactive "$matches" "$search_term")

  # Get display name for the selected codespace
  local display_name=$(echo "$matches" | grep "^$codespace_name" | cut -f2)

  info "Deleting codespace: $display_name"

  # Add confirmation for safety
  read -p "Are you sure you want to delete '$display_name'? [y/N] " -n 1 -r
  echo

  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    info "Cancelled."
    return 0
  fi

  if gh codespace delete -c "$codespace_name" --force; then
    success "Deleted!"
  else
    error "Failed to delete codespace"
  fi
}

cmd_config_init() {
  local config_file="${1:-.spaceheater.conf}"
  local target_location=""

  # Determine where to create the config file
  if [ "$config_file" = ".spaceheater.conf" ]; then
    target_location="repository"
  elif [[ "$config_file" =~ \.config/spaceheater ]]; then
    target_location="user"
  else
    target_location="custom"
  fi

  # Check if file already exists
  if [ -f "$config_file" ]; then
    warn "Config file already exists: $config_file"
    read -p "Overwrite? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      info "Cancelled."
      return 0
    fi
  fi

  # Create parent directory if needed
  local config_dir=$(dirname "$config_file")
  if [ ! -d "$config_dir" ] && [ "$config_dir" != "." ]; then
    mkdir -p "$config_dir"
    info "Created directory: $config_dir"
  fi

  # Create template config file
  cat > "$config_file" << 'EOF'
# Spaceheater Configuration File
# All keys are optional and can be uncommented to override defaults
# Format: KEY=value (no spaces around =)
# Keys do NOT need SPACEHEATER_ prefix in config files

# Repository Settings
# REPO=owner/repo
# BRANCH=main

# Connection Settings
# CONNECT=browser    # Options: browser, ssh, code

# Codespace Overrides
# MACHINE=standardLinux
# RETENTION=168h
# IDLE_TIMEOUT=30m
# DEVCONTAINER_PATH=.devcontainer/devcontainer.json
# DISPLAY_NAME=my-codespace
# LOCATION=WestUs2

# UI Settings
# UI_STYLE=unicode   # Options: unicode, plain, simple

# Debug Settings
# DEBUG=false
EOF

  success "Created config template: $config_file"
  echo ""
  info "Edit this file to customize your configuration."
  info "Lines starting with # are comments and will be ignored."
  echo ""
  info "Config file precedence (highest to lowest):"
  info "  1. Environment variables (SPACEHEATER_*)"
  info "  2. Repository config (.spaceheater.conf)"
  info "  3. User config (~/.config/spaceheater/config)"
  info "  4. System config (/etc/spaceheater/config)"
  info "  5. Built-in defaults"
  echo ""
  info "To edit: spaceheater config edit"
}

cmd_config_edit() {
  local user_config="${XDG_CONFIG_HOME:-$HOME/.config}/spaceheater/config"

  # Check if in a git repo for .spaceheater.conf
  if git rev-parse --git-dir &>/dev/null 2>&1 && [ -f ".spaceheater.conf" ]; then
    info "Found repository config: .spaceheater.conf"
    read -p "Edit repository config instead of user config? [Y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
      user_config=".spaceheater.conf"
    fi
  fi

  # Create config if it doesn't exist
  if [ ! -f "$user_config" ]; then
    info "Config file doesn't exist. Creating template..."
    cmd_config_init "$user_config"
    echo ""
  fi

  # Use $EDITOR or fall back to sensible defaults
  local editor="${EDITOR:-}"
  if [ -z "$editor" ]; then
    if command -v nano &>/dev/null; then
      editor="nano"
    elif command -v vim &>/dev/null; then
      editor="vim"
    elif command -v vi &>/dev/null; then
      editor="vi"
    else
      error "No editor found. Set EDITOR environment variable or install nano/vim."
    fi
  fi

  info "Opening config file in $editor..."
  "$editor" "$user_config"

  success "Config file updated!"
  info "Run 'spaceheater config' to see current configuration."
}

cmd_config() {
