# Get a codespace's display name, falling back to the codespace name on failure.
# Usage: display_name="$(get_display_name <codespace_name>)"
get_display_name() {
  local codespace_name="$1"
  local display_name
  display_name="$(gh codespace view -c "$codespace_name" --json displayName -q .displayName 2>/dev/null)" || display_name="$codespace_name"
  echo "$display_name"
}

# Parse devcontainer.json hostRequirements, warning if the file is malformed.
# Outputs tab-separated cpus and memory values on a single line.
# Usage: IFS=$'\t' read -r cpus memory < <(parse_devcontainer_requirements <file_path>)
parse_devcontainer_requirements() {
  local file_path="$1"
  local result

  if ! result=$(jq -r '[(.hostRequirements.cpus // ""), (.hostRequirements.memory // "")] | map(tostring) | join("\t")' "$file_path" 2>/dev/null); then
    warn "Failed to parse $file_path — file may be malformed"
    printf '\t'
    return
  fi

  printf '%s' "$result"
}

# ============================================================================
# JSON OUTPUT UTILITIES
# ============================================================================

# Returns JQ filter expression for calculating temperature from codespace state
# This centralizes the temperature logic for reuse across commands
get_temperature_jq_filter() {
  cat <<'EOF'
(
  if .state == "Available" then "hot"
  elif .state == "Shutdown" and $is_git_clean and $activity_age_days <= 3 then "warm"
  elif .state | test("Starting|Provisioning|ShuttingDown|Stopping") then "transitioning"
  else "cold"
  end
)
EOF
}

# Returns JQ filter for determining if git status is clean
get_git_clean_jq_filter() {
  cat <<'EOF'
((.git_status.has_uncommitted_changes // false) == false and
 (.git_status.has_unpushed_changes // false) == false and
 (.git_status.ahead // 0) == 0)
EOF
}

# Returns JQ filter for normalizing git status with defaults
get_git_status_normalization_filter() {
  cat <<'EOF'
{
  has_uncommitted_changes: (.git_status.has_uncommitted_changes // false),
  has_unpushed_changes: (.git_status.has_unpushed_changes // false),
  ahead: (.git_status.ahead // 0),
  behind: (.git_status.behind // 0),
  ref: (.git_status.ref // "unknown")
}
EOF
}

# Returns JQ filter for calculating age fields from timestamps
# Note: Timestamps are pre-normalized to UTC Z format by normalize_timestamps()
get_age_calculation_filter() {
  cat <<'EOF'
# Calculate age in seconds and days
(($current_time | fromdate) - (.created_at | fromdate)) as $age_seconds |
($age_seconds / 86400 | floor) as $age_days |

# Calculate last activity (prefer last_used_at over updated_at over created_at)
(.last_used_at // .updated_at // .created_at) as $last_activity |
(($current_time | fromdate) - ($last_activity | fromdate)) as $activity_age_seconds |
($activity_age_seconds / 86400 | floor) as $activity_age_days |
EOF
}

# Returns JQ filter for common codespace fields
# Usage: get_codespace_json_fields [include_optional]
get_codespace_json_fields() {
  local include_optional="${1:-true}"

  cat <<'EOF'
{
  name: .name,
  display_name: .display_name,
  state: .state,
  temperature: TEMPERATURE_PLACEHOLDER,
  is_git_clean: $is_git_clean,
  age_days: $age_days,
  age_seconds: $age_seconds,
  last_activity: $last_activity,
  activity_age_days: $activity_age_days,
  activity_age_seconds: $activity_age_seconds,
  created_at: .created_at,
  updated_at: .updated_at,
  last_used_at: .last_used_at,
  git_status: GIT_STATUS_PLACEHOLDER,
  machine_type: .machine.display_name
EOF

  # Include optional fields if requested
  if [ "$include_optional" = "true" ]; then
    cat <<'EOF'
  ,
  repository: .repository.full_name,
  owner: .owner.login,
  web_url: .web_url,
  recent_folders: .recent_folders,
  environment: .environment,
  prebuild: .prebuild,
  location: .location,
  runtime_constraints: .runtime_constraints
EOF
  fi

  echo "}"
}

# Build complete JQ filter for codespace with temperature
# This combines all the utility filters into a complete transformation
build_codespace_json_filter() {
  local include_optional="${1:-true}"

  # Get the component filters
  local temp_filter
  temp_filter=$(get_temperature_jq_filter)
  local git_clean_filter
  git_clean_filter=$(get_git_clean_jq_filter)
  local git_status_filter
  git_status_filter=$(get_git_status_normalization_filter)
  local age_filter
  age_filter=$(get_age_calculation_filter)
  local fields_filter
  fields_filter=$(get_codespace_json_fields "$include_optional")

  # Replace placeholders with actual filters
  fields_filter="${fields_filter/TEMPERATURE_PLACEHOLDER/$temp_filter}"
  fields_filter="${fields_filter/GIT_STATUS_PLACEHOLDER/$git_status_filter}"

  # Combine all filters
  cat <<EOF
$age_filter
$git_clean_filter as \$is_git_clean |
$fields_filter
EOF
}

# Get connection URL based on connection method (for non-browser, no API call needed)
# For browser/web, pass pre-fetched web_url to avoid redundant API calls.
# Usage: get_connection_url <codespace_name> [web_url]
get_connection_url() {
  local codespace_name="$1"
  local web_url="${2:-}"
  local connection_url=""

  case "$CONNECT_METHOD" in
    browser|web)
      if [ -n "$web_url" ]; then
        connection_url="$web_url"
      else
        connection_url=$(gh api "/user/codespaces/$codespace_name" -q '.web_url')
      fi
      ;;
    ssh)
      connection_url="ssh://$codespace_name"
      ;;
    code|vscode)
      connection_url="vscode://github.codespaces/$codespace_name"
      ;;
  esac

  echo "$connection_url"
}

# Output JSON error
# Usage: output_json_error <action> <error_message> [additional_fields]
output_json_error() {
  local action="$1"
  local error_msg="$2"
  local additional="${3:-}"

  if [ -n "$additional" ]; then
    jq -n \
      --arg action "$action" \
      --arg error "$error_msg" \
      --argjson additional "$additional" \
      '{action: $action, success: false, error: $error, timestamp: (now | todate)} + $additional'
  else
    jq -n \
      --arg action "$action" \
      --arg error "$error_msg" \
      '{action: $action, success: false, error: $error, timestamp: (now | todate)}'
  fi
}

# Output JSON for single codespace commands (start, stop, delete, etc.)
# Usage: output_single_codespace_json <action> <codespace_name> [success_message]
output_single_codespace_json() {
  local action="$1"
  local codespace_name="$2"
  local message="${3:-}"

  # Get the codespace details and transform to JSON
  local codespace_filter
  codespace_filter=$(build_codespace_json_filter false)

  gh api "/user/codespaces/$codespace_name" | normalize_timestamps | jq --arg action "$action" --arg msg "$message" "
    (now | todate) as \$current_time |
    {
      action: \$action,
      success: true,
      message: (if \$msg != \"\" then \$msg else null end),
      codespace: (. | $codespace_filter),
      timestamp: \$current_time
    }
  "
}

# Output JSON for connection commands (start, autostart)
# Single API call — extracts web_url from the fetched data for browser connections.
# Usage: output_connection_json <action> <codespace_name>
output_connection_json() {
  local action="$1"
  local codespace_name="$2"

  # Fetch codespace data (split from transform for clear failure detection)
  local codespace_data
  if ! codespace_data=$(gh api "/user/codespaces/$codespace_name" 2>/dev/null); then
    output_json_error "$action" "Failed to fetch codespace data from API" \
      "$(jq -n --arg name "$codespace_name" '{codespace_name: $name}')"
    return 1
  fi
  codespace_data=$(echo "$codespace_data" | normalize_timestamps)

  # Extract web_url from fetched data for browser connection method
  local web_url
  web_url=$(echo "$codespace_data" | jq -r '.web_url // empty')
  local connection_url
  connection_url=$(get_connection_url "$codespace_name" "$web_url")

  # Transform to JSON output
  local codespace_filter
  codespace_filter=$(build_codespace_json_filter false)

  echo "$codespace_data" | jq \
    --arg action "$action" \
    --arg connection_url "$connection_url" \
    --arg connection_method "$CONNECT_METHOD" \
    "
    (now | todate) as \$current_time |
    {
      action: \$action,
      success: true,
      codespace: (. | $codespace_filter),
      connection_url: \$connection_url,
      connection_method: \$connection_method,
      timestamp: \$current_time
    }
  "
}

# Output JSON for multiple codespace operations (create, clean, etc.)
# Accepts a JSON array of codespace objects via stdin (already normalized).
# Usage: echo "$json_array" | output_multiple_codespaces_json <action> [message]
output_multiple_codespaces_json() {
  local action="$1"
  local message="${2:-}"

  # Transform and output
  local codespace_filter
  codespace_filter=$(build_codespace_json_filter false)

  if [ -n "$message" ]; then
    jq --arg action "$action" --arg msg "$message" "
      (now | todate) as \$current_time |
      {
        action: \$action,
        success: true,
        codespaces: (. | map($codespace_filter)),
        count: . | length,
        message: \$msg,
        timestamp: \$current_time
      }
    "
  else
    jq --arg action "$action" "
      (now | todate) as \$current_time |
      {
        action: \$action,
        success: true,
        codespaces: (. | map($codespace_filter)),
        count: . | length,
        timestamp: \$current_time
      }
    "
  fi
}

# Fetch full codespace details for a list of names, returning a JSON array.
# Usage: fetch_codespaces_by_names <name1> [name2] ...
fetch_codespaces_by_names() {
  local -a names=("$@")
  local results="[]"
  for name in "${names[@]}"; do
    local codespace_data
    codespace_data=$(gh api "/user/codespaces/$name" 2>/dev/null | normalize_timestamps || echo "{}")
    if [ "$codespace_data" != "{}" ]; then
      results=$(echo "$results" | jq --argjson cs "$codespace_data" '. + [$cs]')
    fi
  done
  echo "$results"
}

# Date calculation helper functions
calculate_age_days() {
  local created_at="$1"
  python3 -c "
from datetime import datetime, timezone
created = datetime.fromisoformat('$created_at'.replace('Z', '+00:00'))
now = datetime.now(timezone.utc)
delta = now - created
print(delta.days)
" 2>/dev/null || echo "999"
}

format_time_ago() {
  local created_at="$1"
  python3 -c "
from datetime import datetime, timezone
created = datetime.fromisoformat('$created_at'.replace('Z', '+00:00'))
now = datetime.now(timezone.utc)
delta = now - created
days = delta.days
hours = delta.seconds // 3600
if days > 0:
    print(f'{days}d {hours}h ago')
else:
    print(f'{hours}h ago')
" 2>/dev/null || echo ""
}

# GitHub API wrapper functions
get_all_codespaces() {
  gh api "/user/codespaces?repository_id=$(get_repo_id)" "$@"
}

# Normalize ISO 8601 timestamps with timezone offsets to UTC Z format
# This ensures jq's fromdate can parse timestamps correctly
normalize_timestamps() {
  # Use fd 3 for JSON data, since stdin is used for the Python script heredoc
  python3 /dev/stdin 3<&0 <<'PYTHON_SCRIPT'
import sys
import json
import os
from datetime import datetime, timezone

# Timestamp fields to normalize
TIMESTAMP_FIELDS = ['created_at', 'updated_at', 'last_used_at']

def normalize_timestamp(timestamp_str):
    """Convert ISO 8601 timestamp with timezone offset to UTC Z format."""
    if not timestamp_str:
        return timestamp_str
    try:
        dt = datetime.fromisoformat(timestamp_str)
        utc_dt = dt.astimezone(timezone.utc)
        return utc_dt.strftime('%Y-%m-%dT%H:%M:%SZ')
    except (ValueError, AttributeError):
        return timestamp_str

def normalize_object(obj):
    """Normalize timestamp fields recursively."""
    if not isinstance(obj, dict):
        return obj

    normalized = {}
    for key, value in obj.items():
        if key in TIMESTAMP_FIELDS and isinstance(value, str):
            normalized[key] = normalize_timestamp(value)
        elif isinstance(value, dict):
            normalized[key] = normalize_object(value)
        elif isinstance(value, list):
            normalized[key] = [normalize_object(item) if isinstance(item, dict) else item for item in value]
        else:
            normalized[key] = value
    return normalized

try:
    # Read JSON from fd 3 (original stdin before heredoc redirection)
    with os.fdopen(3, 'r') as f:
        data = json.load(f)
    normalized = [normalize_object(obj) for obj in data] if isinstance(data, list) else normalize_object(data)
    json.dump(normalized, sys.stdout)
except json.JSONDecodeError as e:
    print(f"Error: Invalid JSON input: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"Error: {e}", file=sys.stderr)
    sys.exit(1)
PYTHON_SCRIPT
}

get_codespaces_with_jq() {
  local jq_filter="$1"
  get_all_codespaces --jq "$jq_filter"
}

get_available_machines() {
  gh api "/repos/$REPO/codespaces/machines" "$@"
}

find_codespace_by_pattern() {
  local search_term="$1"
  get_codespaces_with_jq '.codespaces | .[] | "\(.name)\t\(.display_name // .name)"' | \
    grep -i "$search_term" || true
}

# Interactive selection helper
# Returns the selected codespace name via echo
# Usage: codespace_name=$(select_codespace_interactive "$matches" "$search_term")
select_codespace_interactive() {
  local matches="$1"
  local search_term="$2"
  local codespace_name=""

  # Check if matches is empty
  if [ -z "$matches" ]; then
    error "No codespace found matching: $search_term"
  fi

  # Count matches
  local match_count
  match_count=$(echo "$matches" | wc -l | tr -d ' ')

  if [ "$match_count" -eq 1 ]; then
    # Single match - use it
    codespace_name=$(echo "$matches" | cut -f1)
    local display_name
    display_name=$(echo "$matches" | cut -f2)
    debug "Found match: $display_name"
  else
    # Multiple matches - let user select interactively
    info "Multiple codespaces match '$search_term':"
    echo >&2

    # Build arrays for selection
    local -a display_names=()
    local -a codespace_names=()
    while IFS=$'\t' read -r name display; do
      codespace_names+=("$name")
      display_names+=("$display")
    done <<< "$matches"

    # Interactive selection
    PS3="Select codespace number: "
    select display_name in "${display_names[@]}"; do
      if [ -n "$display_name" ]; then
        local index=$((REPLY - 1))
        codespace_name="${codespace_names[$index]}"
        debug "Selected: $display_name"
        break
      else
        echo "Invalid selection. Please try again." >&2
      fi
    done
  fi

  echo "$codespace_name"
}

