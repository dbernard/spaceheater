# --- Terminal Capability Detection ---

detect_unicode() {
  # Check NO_COLOR first
  if [ "${NO_COLOR:-}" != "" ]; then
    return 1
  fi
  # Check for simple/plain UI mode
  if [ "${SPACEHEATER_UI_STYLE:-}" = "plain" ] || [ "${SPACEHEATER_UI_STYLE:-}" = "simple" ]; then
    return 1
  fi
  # Check LANG for UTF-8 support and terminal type
  if [[ "${LANG:-}" == *UTF-8* ]] && [[ "${TERM:-}" != "linux" ]] && [[ "${TERM:-}" != "dumb" ]]; then
    return 0
  fi
  return 1
}

